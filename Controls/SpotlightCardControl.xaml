<UserControl x:Class="KanbanForOne.Controls.SpotlightCardControl"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:KanbanForOne.Controls"
             xmlns:models="clr-namespace:KanbanForOne.Models"
             Focusable="True"
             PreviewKeyDown="OnPreviewKeyDown"
             IsVisibleChanged="OnIsVisibleChanged">
    <UserControl.Resources>
        <SolidColorBrush x:Key="SpotlightTextPrimaryBrush" Color="#111827" />
        <SolidColorBrush x:Key="SpotlightTextSecondaryBrush" Color="#64748B" />
        <SolidColorBrush x:Key="SpotlightTextMutedBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="SpotlightSurfaceDialogBrush" Color="#F8FBFF" />
        <SolidColorBrush x:Key="SpotlightSurfaceBlockBrush" Color="#B8FFFFFF" />
        <SolidColorBrush x:Key="SpotlightSurfaceInputBrush" Color="#CCFFFFFF" />
        <SolidColorBrush x:Key="SpotlightBorderSoftBrush" Color="#E5E7EB" />
        <SolidColorBrush x:Key="SpotlightPrimaryBrush" Color="#111827" />

        <Style x:Key="SpotlightShellStyle" TargetType="{x:Type Border}">
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Background" Value="{StaticResource SpotlightSurfaceDialogBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SpotlightBorderSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="38"
                                      ShadowDepth="12"
                                      Direction="270"
                                      Opacity="0.14" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SpotlightTitleTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource SpotlightTextPrimaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="32" />
        </Style>

        <Style x:Key="SpotlightTitleBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="MinHeight" Value="50" />
            <Setter Property="FontSize" Value="26" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource SpotlightTextPrimaryBrush}" />
            <Setter Property="CaretBrush" Value="#111827" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,6" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="AcceptsReturn" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#73FFFFFF" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#D8E0EA" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#A6FFFFFF" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#BFDBFE" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SpotlightSectionLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource SpotlightTextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,7" />
        </Style>

        <Style x:Key="SpotlightMetaPanelStyle" TargetType="{x:Type Border}">
            <Setter Property="Height" Value="64" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Background" Value="{StaticResource SpotlightSurfaceBlockBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SpotlightBorderSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#BFDBFE" />
                    <Setter Property="Background" Value="#CCFFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SpotlightPropertyPanelStyle" TargetType="{x:Type Border}">
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Background" Value="{StaticResource SpotlightSurfaceBlockBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SpotlightBorderSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="SpotlightPropertyLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Width" Value="56" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource SpotlightTextSecondaryBrush}" />
        </Style>

        <Style x:Key="SpotlightPanelRowStyle" TargetType="{x:Type Grid}">
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="SpotlightTagStyle" TargetType="{x:Type Border}">
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="Margin" Value="0,0,7,7" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Background" Value="#DFFFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource SpotlightBorderSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="SpotlightScrollBarStyle"
               TargetType="{x:Type ScrollBar}"
               BasedOn="{StaticResource DrawerScrollBarStyle}">
            <Setter Property="Width" Value="6" />
            <Setter Property="MinWidth" Value="6" />
            <Setter Property="Opacity" Value="0.55" />
        </Style>

        <Style x:Key="SpotlightDescriptionTextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="MinHeight" Value="160" />
            <Setter Property="MaxHeight" Value="240" />
            <Setter Property="Padding" Value="16,14" />
            <Setter Property="Background" Value="{StaticResource SpotlightSurfaceInputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SpotlightBorderSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#1F2937" />
            <Setter Property="CaretBrush" Value="#111827" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}">
                                <ScrollViewer.Resources>
                                    <Style TargetType="{x:Type ScrollBar}"
                                           BasedOn="{StaticResource SpotlightScrollBarStyle}" />
                                </ScrollViewer.Resources>
                            </ScrollViewer>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#BFDBFE" />
                                <Setter TargetName="Chrome" Property="Background" Value="#D9FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SpotlightHeaderChipStyle" TargetType="{x:Type Border}">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="SpotlightSegmentButtonStyle" TargetType="{x:Type RadioButton}">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="74" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Border x:Name="Chrome"
                                Padding="{TemplateBinding Padding}"
                                Background="#BFFFFFFF"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#FFFFFFFF" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#CBD5E1" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource SegmentSelectedBackground}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource SegmentSelectedBorderBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource SegmentSelectedForeground}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SpotlightTodoSegmentButtonStyle"
               BasedOn="{StaticResource SpotlightSegmentButtonStyle}"
               TargetType="{x:Type RadioButton}">
            <Style.Resources>
                <SolidColorBrush x:Key="SegmentSelectedBackground" Color="#F1F5F9" />
                <SolidColorBrush x:Key="SegmentSelectedBorderBrush" Color="#CBD5E1" />
                <SolidColorBrush x:Key="SegmentSelectedForeground" Color="#475569" />
            </Style.Resources>
        </Style>

        <Style x:Key="SpotlightDoingSegmentButtonStyle"
               BasedOn="{StaticResource SpotlightSegmentButtonStyle}"
               TargetType="{x:Type RadioButton}">
            <Style.Resources>
                <SolidColorBrush x:Key="SegmentSelectedBackground" Color="#EFF6FF" />
                <SolidColorBrush x:Key="SegmentSelectedBorderBrush" Color="#BFDBFE" />
                <SolidColorBrush x:Key="SegmentSelectedForeground" Color="#2563EB" />
            </Style.Resources>
        </Style>

        <Style x:Key="SpotlightBlockedSegmentButtonStyle"
               BasedOn="{StaticResource SpotlightSegmentButtonStyle}"
               TargetType="{x:Type RadioButton}">
            <Style.Resources>
                <SolidColorBrush x:Key="SegmentSelectedBackground" Color="#FFF7ED" />
                <SolidColorBrush x:Key="SegmentSelectedBorderBrush" Color="#FDBA74" />
                <SolidColorBrush x:Key="SegmentSelectedForeground" Color="#EA580C" />
            </Style.Resources>
        </Style>

        <Style x:Key="SpotlightDoneSegmentButtonStyle"
               BasedOn="{StaticResource SpotlightSegmentButtonStyle}"
               TargetType="{x:Type RadioButton}">
            <Style.Resources>
                <SolidColorBrush x:Key="SegmentSelectedBackground" Color="#ECFDF5" />
                <SolidColorBrush x:Key="SegmentSelectedBorderBrush" Color="#A7F3D0" />
                <SolidColorBrush x:Key="SegmentSelectedForeground" Color="#059669" />
            </Style.Resources>
        </Style>

        <Style x:Key="SpotlightHighSegmentButtonStyle"
               BasedOn="{StaticResource SpotlightSegmentButtonStyle}"
               TargetType="{x:Type RadioButton}">
            <Style.Resources>
                <SolidColorBrush x:Key="SegmentSelectedBackground" Color="#FEF2F2" />
                <SolidColorBrush x:Key="SegmentSelectedBorderBrush" Color="#FECACA" />
                <SolidColorBrush x:Key="SegmentSelectedForeground" Color="#DC2626" />
            </Style.Resources>
        </Style>

        <Style x:Key="SpotlightMediumSegmentButtonStyle"
               BasedOn="{StaticResource SpotlightSegmentButtonStyle}"
               TargetType="{x:Type RadioButton}">
            <Style.Resources>
                <SolidColorBrush x:Key="SegmentSelectedBackground" Color="#FFF7ED" />
                <SolidColorBrush x:Key="SegmentSelectedBorderBrush" Color="#FED7AA" />
                <SolidColorBrush x:Key="SegmentSelectedForeground" Color="#EA580C" />
            </Style.Resources>
        </Style>

        <Style x:Key="SpotlightLowSegmentButtonStyle"
               BasedOn="{StaticResource SpotlightSegmentButtonStyle}"
               TargetType="{x:Type RadioButton}">
            <Style.Resources>
                <SolidColorBrush x:Key="SegmentSelectedBackground" Color="#F8FAFC" />
                <SolidColorBrush x:Key="SegmentSelectedBorderBrush" Color="#E2E8F0" />
                <SolidColorBrush x:Key="SegmentSelectedForeground" Color="#475569" />
            </Style.Resources>
        </Style>

        <Style x:Key="SpotlightActionButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="76" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="#DFFFFFFF" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#EFFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#D9FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Background" Value="#F1F5F9" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#E5E7EB" />
                                <Setter Property="Foreground" Value="#9CA3AF" />
                                <Setter Property="Opacity" Value="1" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SpotlightPrimaryActionButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource SpotlightActionButtonStyle}">
            <Setter Property="Background" Value="#1F2937" />
            <Setter Property="BorderBrush" Value="#1F2937" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#334155" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#334155" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#111827" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#111827" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Background" Value="#E5E7EB" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#E5E7EB" />
                                <Setter Property="Foreground" Value="#9CA3AF" />
                                <Setter Property="Opacity" Value="1" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SpotlightDangerActionButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource SpotlightActionButtonStyle}">
            <Setter Property="Background" Value="#FFF1F2" />
            <Setter Property="BorderBrush" Value="#FECDD3" />
            <Setter Property="Foreground" Value="#BE123C" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#FFE4E6" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#FDA4AF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#FECDD3" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SpotlightCloseButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#EFFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#D9FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="OverlaySurface"
          Background="Transparent"
          MouseLeftButtonDown="OnOverlayMouseLeftButtonDown">
        <Border x:Name="Backdrop"
                Background="#1F0F172A"
                Opacity="0" />
        <Canvas ClipToBounds="True">
        <Border x:Name="TaskShell"
                Style="{StaticResource SpotlightShellStyle}"
                Canvas.Left="{Binding SpotlightLeft}"
                Canvas.Top="{Binding SpotlightTop}"
                Width="{Binding SpotlightWidth}"
                Height="{Binding SpotlightHeight}"
                Background="#F8FBFF"
                BorderBrush="#E5E7EB"
                Opacity="0"
                Visibility="{Binding IsTaskSpotlightOpen, Converter={StaticResource BooleanToVisibilityConverterEx}}">
            <Grid x:Name="TaskDetailContent"
                  Opacity="0">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="TaskDetailTransform"
                                        Y="-8" />
                </Grid.RenderTransform>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Width="4"
                        Height="42"
                        Margin="20,22,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Opacity="0.42"
                        Background="{Binding FocusedTask.Status, Converter={StaticResource TaskStatusBrushConverter}}"
                        CornerRadius="999" />

                <Grid Grid.Row="0"
                      Margin="34,20,24,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsTaskSpotlightPreviewing, Converter={StaticResource BooleanToVisibilityConverterEx}}">
                        <Border Style="{StaticResource SpotlightHeaderChipStyle}"
                                Background="{Binding FocusedTask.Status, Converter={StaticResource TaskStatusBackgroundConverter}}">
                            <TextBlock Text="{Binding FocusedTask.Status, Converter={StaticResource TaskStatusNameConverter}}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding FocusedTask.Status, Converter={StaticResource TaskStatusBrushConverter}}" />
                        </Border>

                        <Border Margin="8,0,0,0"
                                Style="{StaticResource SpotlightHeaderChipStyle}"
                                Background="#FFF7ED">
                            <TextBlock Text="{Binding FocusedTask.Priority, Converter={StaticResource TaskPriorityNameConverter}, StringFormat=&#x4F18;&#x5148;&#x7EA7; {0}}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding FocusedTask.Priority, Converter={StaticResource TaskPriorityBrushConverter}}" />
                        </Border>

                        <Border Margin="8,0,0,0"
                                Style="{StaticResource SpotlightHeaderChipStyle}"
                                Background="#EEF2F7"
                                Visibility="{Binding HasUnsavedTaskChanges, Converter={StaticResource BooleanToVisibilityConverterEx}}">
                            <TextBlock Text="&#x672A;&#x4FDD;&#x5B58;"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#475569" />
                        </Border>
                    </StackPanel>

                    <StackPanel VerticalAlignment="Center"
                                Visibility="{Binding IsTaskSpotlightEditing, Converter={StaticResource BooleanToVisibilityConverterEx}}">
                        <TextBlock Text="&#x7F16;&#x8F91;&#x4EFB;&#x52A1;"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource SpotlightTextPrimaryBrush}" />
                        <TextBlock Text="&#x4FEE;&#x6539;&#x4EFB;&#x52A1;&#x5185;&#x5BB9;&#x3001;&#x72B6;&#x6001;&#x3001;&#x65E5;&#x671F;&#x548C;&#x9644;&#x4EF6;"
                                   Margin="0,4,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource SpotlightTextMutedBrush}" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="&#xD7;"
                            Click="OnCloseButtonClick"
                            Style="{StaticResource SpotlightCloseButtonStyle}"
                            ToolTip="&#x6536;&#x8D77;" />
                </Grid>

                <ScrollViewer Grid.Row="1"
                              Padding="34,0,24,4"
                              VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Resources>
                        <Style TargetType="{x:Type ScrollBar}"
                               BasedOn="{StaticResource SpotlightScrollBarStyle}" />
                    </ScrollViewer.Resources>
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="{Binding FocusedTask.Title}"
                                       Style="{StaticResource SpotlightTitleTextStyle}"
                                       Visibility="{Binding IsTaskSpotlightPreviewing, Converter={StaticResource BooleanToVisibilityConverterEx}}" />
                            <TextBox Text="{Binding TaskTitleDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     x:Name="TaskTitleEditor"
                                     Style="{StaticResource SpotlightTitleBoxStyle}"
                                     IsVisibleChanged="OnEditorIsVisibleChanged"
                                     Visibility="{Binding IsTaskSpotlightEditing, Converter={StaticResource BooleanToVisibilityConverterEx}}" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding FocusedTask.Tags}"
                                      Margin="0,12,0,4"
                                      Visibility="{Binding IsTaskSpotlightPreviewing, Converter={StaticResource BooleanToVisibilityConverterEx}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource SpotlightTagStyle}">
                                        <TextBlock Text="{Binding Converter={StaticResource TagDisplayConverter}}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="#475569" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Margin="0,18,0,0"
                                    Visibility="{Binding IsTaskSpotlightEditing, Converter={StaticResource BooleanToVisibilityConverterEx}}">
                            <TextBlock Text="&#x5C5E;&#x6027;"
                                       Style="{StaticResource SpotlightSectionLabelStyle}" />
                            <Border Style="{StaticResource SpotlightPropertyPanelStyle}">
                                <StackPanel>
                                    <Grid Style="{StaticResource SpotlightPanelRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="56" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#x72B6;&#x6001;"
                                                   Style="{StaticResource SpotlightPropertyLabelStyle}" />
                                        <WrapPanel Grid.Column="1">
                                            <RadioButton Content="&#x5F85;&#x529E;"
                                                         Tag="{x:Static models:TaskStatus.Todo}"
                                                         IsChecked="{Binding TaskStatusDraft, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Todo, Mode=TwoWay}"
                                                         Style="{StaticResource SpotlightTodoSegmentButtonStyle}" />
                                            <RadioButton Content="&#x8FDB;&#x884C;&#x4E2D;"
                                                         Tag="{x:Static models:TaskStatus.Doing}"
                                                         IsChecked="{Binding TaskStatusDraft, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Doing, Mode=TwoWay}"
                                                         Style="{StaticResource SpotlightDoingSegmentButtonStyle}" />
                                            <RadioButton Content="&#x5361;&#x4F4F;"
                                                         Tag="{x:Static models:TaskStatus.Blocked}"
                                                         IsChecked="{Binding TaskStatusDraft, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Blocked, Mode=TwoWay}"
                                                         Style="{StaticResource SpotlightBlockedSegmentButtonStyle}" />
                                            <RadioButton Content="&#x5B8C;&#x6210;"
                                                         Tag="{x:Static models:TaskStatus.Done}"
                                                         IsChecked="{Binding TaskStatusDraft, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Done, Mode=TwoWay}"
                                                         Style="{StaticResource SpotlightDoneSegmentButtonStyle}" />
                                        </WrapPanel>
                                    </Grid>

                                    <Grid Style="{StaticResource SpotlightPanelRowStyle}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="56" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#x4F18;&#x5148;&#x7EA7;"
                                                   Style="{StaticResource SpotlightPropertyLabelStyle}" />
                                        <WrapPanel Grid.Column="1">
                                            <RadioButton Content="&#x9AD8;"
                                                         IsChecked="{Binding TaskPriorityDraft, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=High, Mode=TwoWay}"
                                                         Style="{StaticResource SpotlightHighSegmentButtonStyle}" />
                                            <RadioButton Content="&#x4E2D;"
                                                         IsChecked="{Binding TaskPriorityDraft, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Medium, Mode=TwoWay}"
                                                         Style="{StaticResource SpotlightMediumSegmentButtonStyle}" />
                                            <RadioButton Content="&#x4F4E;"
                                                         IsChecked="{Binding TaskPriorityDraft, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Low, Mode=TwoWay}"
                                                         Style="{StaticResource SpotlightLowSegmentButtonStyle}" />
                                        </WrapPanel>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="56" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#x6807;&#x7B7E;"
                                                   Style="{StaticResource SpotlightPropertyLabelStyle}" />
                                        <controls:TagChipEditorControl Grid.Column="1"
                                                                       Text="{Binding TaskTagsDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                       EditorBackground="#AAFFFFFF"
                                                                       EditorBorderBrush="#E5E7EB"
                                                                       ChipBackground="#F1F5F9"
                                                                       ChipForeground="#334155" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource SpotlightMetaPanelStyle}">
                                <StackPanel>
                                    <TextBlock Text="&#x8D77;&#x59CB;"
                                               Style="{StaticResource SpotlightSectionLabelStyle}" />
                                    <TextBlock Text="{Binding FocusedTask.StartDate, StringFormat={}{0:yyyy/M/d}, TargetNullValue=&#x672A;&#x8BBE;&#x7F6E;}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Visibility="{Binding IsTaskSpotlightPreviewing, Converter={StaticResource BooleanToVisibilityConverterEx}}" />
                                    <DatePicker SelectedDate="{Binding TaskStartDateDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Style="{StaticResource DrawerDatePickerStyle}"
                                                Visibility="{Binding IsTaskSpotlightEditing, Converter={StaticResource BooleanToVisibilityConverterEx}}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Style="{StaticResource SpotlightMetaPanelStyle}">
                                <StackPanel>
                                    <TextBlock Text="&#x622A;&#x6B62;"
                                               Style="{StaticResource SpotlightSectionLabelStyle}" />
                                    <TextBlock Text="{Binding FocusedTask.EndDate, StringFormat={}{0:yyyy/M/d}, TargetNullValue=&#x672A;&#x8BBE;&#x7F6E;}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Visibility="{Binding IsTaskSpotlightPreviewing, Converter={StaticResource BooleanToVisibilityConverterEx}}" />
                                    <DatePicker SelectedDate="{Binding TaskEndDateDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Style="{StaticResource DrawerDatePickerStyle}"
                                                Visibility="{Binding IsTaskSpotlightEditing, Converter={StaticResource BooleanToVisibilityConverterEx}}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBlock Text="&#x63CF;&#x8FF0;"
                                   Style="{StaticResource SpotlightSectionLabelStyle}"
                                   Margin="0,18,0,7" />
                        <controls:MarkdownViewerControl Markdown="{Binding FocusedTask.Description}"
                                                        ViewerBackground="#7AFFFFFF"
                                                        ViewerBorderBrush="#33E5E7EB"
                                                        ViewerForeground="#1F2937"
                                                        ForwardMouseWheelToParentScrollViewer="True"
                                                        MinHeight="130"
                                                        MaxHeight="220"
                                                        Visibility="{Binding IsTaskSpotlightPreviewing, Converter={StaticResource BooleanToVisibilityConverterEx}}" />
                        <TextBox Text="{Binding TaskDescriptionDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SpotlightDescriptionTextBoxStyle}"
                                 MinHeight="180"
                                 MaxHeight="260"
                                 Visibility="{Binding IsTaskSpotlightEditing, Converter={StaticResource BooleanToVisibilityConverterEx}}" />

                        <Grid Margin="0,18,0,8">
                            <TextBlock Text="{Binding FocusedTask.AttachmentCount, StringFormat=&#x9644;&#x4EF6; {0}}"
                                       Style="{StaticResource SpotlightSectionLabelStyle}" />
                            <Button Content="+ &#x6DFB;&#x52A0;&#x9644;&#x4EF6;"
                                    Command="{Binding PickFilesCommand}"
                                    CommandParameter="{Binding FocusedTask}"
                                    Style="{StaticResource SpotlightActionButtonStyle}"
                                    HorizontalAlignment="Right"
                                    Height="30"
                                    Visibility="{Binding IsTaskSpotlightEditing, Converter={StaticResource BooleanToVisibilityConverterEx}}" />
                        </Grid>

                        <controls:AttachmentDropZoneControl Owner="{Binding FocusedTask}"
                                                            AttachFilesCommand="{Binding AttachFilesCommand}"
                                                            TitleText="拖拽文件到这里添加"
                                                            HelperText="或点击右上角选择文件"
                                                            DropHintText="释放文件以添加附件"
                                                            Visibility="{Binding IsTaskSpotlightEditing, Converter={StaticResource BooleanToVisibilityConverterEx}}" />

                        <StackPanel Visibility="{Binding IsTaskSpotlightPreviewing, Converter={StaticResource BooleanToVisibilityConverterEx}}">
                            <Border Padding="10,8"
                                    CornerRadius="12"
                                    Background="#55FFFFFF"
                                    Visibility="{Binding IsFocusedTaskAttachmentEmpty, Converter={StaticResource BooleanToVisibilityConverterEx}}">
                                <StackPanel>
                                    <TextBlock Text="暂无附件"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource SpotlightTextSecondaryBrush}" />
                                    <TextBlock Text="可在编辑模式中添加附件"
                                               Margin="0,3,0,0"
                                               FontSize="11"
                                               Foreground="{StaticResource SpotlightTextMutedBrush}" />
                                </StackPanel>
                            </Border>

                            <ItemsControl ItemsSource="{Binding FocusedTask.Attachments}"
                                          Visibility="{Binding IsFocusedTaskAttachmentEmpty, Converter={StaticResource BooleanToVisibilityConverterEx}, ConverterParameter=Invert}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,6"
                                                Padding="10"
                                                CornerRadius="8"
                                                Background="#F8FAFC"
                                                BorderBrush="#E2E8F0"
                                                BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding OriginalFileName}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding FileSizeBytes, Converter={StaticResource AttachmentSizeConverter}}"
                                                           Margin="12,0,0,0"
                                                           FontSize="11"
                                                           Foreground="#64748B" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        <controls:AttachmentListControl ItemsSource="{Binding FocusedTask.Attachments}"
                                                        OpenCommand="{Binding OpenAttachmentCommand}"
                                                        RevealCommand="{Binding RevealAttachmentCommand}"
                                                        DeleteCommand="{Binding DeleteAttachmentCommand}"
                                                        Margin="0,8,0,0"
                                                        Visibility="{Binding IsTaskSpotlightEditing, Converter={StaticResource BooleanToVisibilityConverterEx}}" />
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Padding="34,10,24,18"
                        Background="{StaticResource SpotlightSurfaceDialogBrush}"
                        BorderBrush="#55E5E7EB"
                        BorderThickness="0,1,0,0"
                        CornerRadius="0,0,24,24">
                    <Grid>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Left">
                            <Button Content="&#x5220;&#x9664;"
                                    Command="{Binding DeleteTaskCommand}"
                                    Style="{StaticResource SpotlightDangerActionButtonStyle}" />
                            <Button Content="{Binding TaskArchiveActionText}"
                                    Command="{Binding ArchiveTaskCommand}"
                                    Style="{StaticResource SpotlightActionButtonStyle}"
                                    Margin="8,0,0,0" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Visibility="{Binding IsTaskSpotlightPreviewing, Converter={StaticResource BooleanToVisibilityConverterEx}}">
                            <Button Content="&#x7F16;&#x8F91;"
                                    Command="{Binding EditSpotlightCommand}"
                                    Style="{StaticResource SpotlightPrimaryActionButtonStyle}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Visibility="{Binding IsTaskSpotlightEditing, Converter={StaticResource BooleanToVisibilityConverterEx}}">
                            <Button Content="&#x53D6;&#x6D88;"
                                    Command="{Binding CancelSpotlightEditCommand}"
                                    Style="{StaticResource SpotlightActionButtonStyle}"
                                    Margin="0,0,10,0" />
                            <Button Content="&#x4FDD;&#x5B58;"
                                    Command="{Binding SaveTaskCommand}"
                                    Style="{StaticResource SpotlightPrimaryActionButtonStyle}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="NoteShell"
                Style="{StaticResource SpotlightShellStyle}"
                Canvas.Left="{Binding SpotlightLeft}"
                Canvas.Top="{Binding SpotlightTop}"
                Width="{Binding SpotlightWidth}"
                Height="{Binding SpotlightHeight}"
                Background="#FAFAF7"
                BorderBrush="#E5E7EB"
                Opacity="0"
                Visibility="{Binding IsNoteSpotlightOpen, Converter={StaticResource BooleanToVisibilityConverterEx}}">
            <Grid x:Name="NoteDetailContent"
                  Opacity="0">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="NoteDetailTransform"
                                        Y="-8" />
                </Grid.RenderTransform>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Width="4"
                        Height="42"
                        Margin="20,22,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Opacity="0.36"
                        Background="#B45309"
                        CornerRadius="999" />

                <Grid Grid.Row="0"
                      Margin="34,20,24,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsNoteSpotlightPreviewing, Converter={StaticResource BooleanToVisibilityConverterEx}}">
                        <Border Style="{StaticResource SpotlightHeaderChipStyle}"
                                Background="#FFF7ED">
                            <TextBlock Text="&#x5907;&#x5FD8;"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#9A3412" />
                        </Border>
                        <Border Margin="8,0,0,0"
                                Style="{StaticResource SpotlightHeaderChipStyle}"
                                Background="#F1F5F9"
                                Visibility="{Binding HasUnsavedNoteChanges, Converter={StaticResource BooleanToVisibilityConverterEx}}">
                            <TextBlock Text="&#x672A;&#x4FDD;&#x5B58;"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#475569" />
                        </Border>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Center"
                                Visibility="{Binding IsNoteSpotlightEditing, Converter={StaticResource BooleanToVisibilityConverterEx}}">
                        <TextBlock Text="&#x7F16;&#x8F91;&#x5907;&#x5FD8;"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource SpotlightTextPrimaryBrush}" />
                        <TextBlock Text="&#x4FEE;&#x6539;&#x5907;&#x5FD8;&#x5185;&#x5BB9;&#x3001;&#x6807;&#x7B7E;&#x548C;&#x9644;&#x4EF6;"
                                   Margin="0,4,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource SpotlightTextMutedBrush}" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="&#xD7;"
                            Click="OnCloseButtonClick"
                            Style="{StaticResource SpotlightCloseButtonStyle}"
                            ToolTip="&#x6536;&#x8D77;" />
                </Grid>

                <ScrollViewer Grid.Row="1"
                              Padding="34,0,24,4"
                              VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Resources>
                        <Style TargetType="{x:Type ScrollBar}"
                               BasedOn="{StaticResource SpotlightScrollBarStyle}" />
                    </ScrollViewer.Resources>
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="{Binding FocusedNote.Title}"
                                       Style="{StaticResource SpotlightTitleTextStyle}"
                                       Visibility="{Binding IsNoteSpotlightPreviewing, Converter={StaticResource BooleanToVisibilityConverterEx}}" />
                            <TextBox Text="{Binding NoteTitleDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     x:Name="NoteTitleEditor"
                                     Style="{StaticResource SpotlightTitleBoxStyle}"
                                     IsVisibleChanged="OnEditorIsVisibleChanged"
                                     Visibility="{Binding IsNoteSpotlightEditing, Converter={StaticResource BooleanToVisibilityConverterEx}}" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding FocusedNote.Tags}"
                                      Margin="0,12,0,4"
                                      Visibility="{Binding IsNoteSpotlightPreviewing, Converter={StaticResource BooleanToVisibilityConverterEx}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,4"
                                            Margin="0,0,7,7"
                                            CornerRadius="8"
                                            Background="#FFF7ED"
                                            BorderBrush="#FED7AA"
                                            BorderThickness="1">
                                        <TextBlock Text="{Binding Converter={StaticResource TagDisplayConverter}}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="#9A3412" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Visibility="{Binding IsNoteSpotlightEditing, Converter={StaticResource BooleanToVisibilityConverterEx}}">
                            <TextBlock Text="&#x6807;&#x7B7E;"
                                       Style="{StaticResource SpotlightSectionLabelStyle}"
                                       Margin="0,14,0,7" />
                            <controls:TagChipEditorControl Text="{Binding NoteTagsDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                           EditorBackground="#B8FFFFFF"
                                                           EditorBorderBrush="#E5E7EB"
                                                           ChipBackground="#FFF7ED"
                                                           ChipForeground="#9A3412" />
                        </StackPanel>

                        <TextBlock Text="&#x5185;&#x5BB9;"
                                   Style="{StaticResource SpotlightSectionLabelStyle}"
                                   Margin="0,16,0,7" />
                        <controls:MarkdownViewerControl Markdown="{Binding FocusedNote.Content}"
                                                        ViewerBackground="#7AFFFFFF"
                                                        ViewerBorderBrush="#33E5E7EB"
                                                        ViewerForeground="#1F2937"
                                                        ForwardMouseWheelToParentScrollViewer="True"
                                                        MinHeight="150"
                                                        MaxHeight="230"
                                                        Visibility="{Binding IsNoteSpotlightPreviewing, Converter={StaticResource BooleanToVisibilityConverterEx}}" />
                        <TextBox Text="{Binding NoteContentDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SpotlightDescriptionTextBoxStyle}"
                                 MinHeight="260"
                                 MaxHeight="300"
                                 Background="#B8FFFFFF"
                                 BorderBrush="#E5E7EB"
                                 Visibility="{Binding IsNoteSpotlightEditing, Converter={StaticResource BooleanToVisibilityConverterEx}}" />

                        <Grid Margin="0,16,0,8">
                            <TextBlock Text="{Binding FocusedNote.AttachmentCount, StringFormat=&#x9644;&#x4EF6; {0}}"
                                       Style="{StaticResource SpotlightSectionLabelStyle}" />
                            <Button Content="+ &#x6DFB;&#x52A0;&#x9644;&#x4EF6;"
                                    Command="{Binding PickFilesCommand}"
                                    CommandParameter="{Binding FocusedNote}"
                                    Style="{StaticResource SpotlightActionButtonStyle}"
                                    HorizontalAlignment="Right"
                                    Height="30"
                                    Visibility="{Binding IsNoteSpotlightEditing, Converter={StaticResource BooleanToVisibilityConverterEx}}" />
                        </Grid>

                        <controls:AttachmentDropZoneControl Owner="{Binding FocusedNote}"
                                                            AttachFilesCommand="{Binding AttachFilesCommand}"
                                                            TitleText="拖拽文件到这里添加"
                                                            HelperText="或点击右上角选择文件"
                                                            DropHintText="释放文件以添加附件"
                                                            Visibility="{Binding IsNoteSpotlightEditing, Converter={StaticResource BooleanToVisibilityConverterEx}}" />

                        <StackPanel Visibility="{Binding IsNoteSpotlightPreviewing, Converter={StaticResource BooleanToVisibilityConverterEx}}">
                            <Border Padding="10,8"
                                    CornerRadius="12"
                                    Background="#55FFFFFF"
                                    Visibility="{Binding IsFocusedNoteAttachmentEmpty, Converter={StaticResource BooleanToVisibilityConverterEx}}">
                                <StackPanel>
                                    <TextBlock Text="暂无附件"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource SpotlightTextSecondaryBrush}" />
                                    <TextBlock Text="可在编辑模式中添加附件"
                                               Margin="0,3,0,0"
                                               FontSize="11"
                                               Foreground="{StaticResource SpotlightTextMutedBrush}" />
                                </StackPanel>
                            </Border>

                            <ItemsControl ItemsSource="{Binding FocusedNote.Attachments}"
                                          Visibility="{Binding IsFocusedNoteAttachmentEmpty, Converter={StaticResource BooleanToVisibilityConverterEx}, ConverterParameter=Invert}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,6"
                                                Padding="10"
                                                CornerRadius="8"
                                                Background="#F8FAFC"
                                                BorderBrush="#E2E8F0"
                                                BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding OriginalFileName}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding FileSizeBytes, Converter={StaticResource AttachmentSizeConverter}}"
                                                           Margin="12,0,0,0"
                                                           FontSize="11"
                                                           Foreground="#64748B" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        <controls:AttachmentListControl ItemsSource="{Binding FocusedNote.Attachments}"
                                                        OpenCommand="{Binding OpenAttachmentCommand}"
                                                        RevealCommand="{Binding RevealAttachmentCommand}"
                                                        DeleteCommand="{Binding DeleteAttachmentCommand}"
                                                        Margin="0,8,0,0"
                                                        Visibility="{Binding IsNoteSpotlightEditing, Converter={StaticResource BooleanToVisibilityConverterEx}}" />
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Padding="34,10,24,18"
                        Background="#FAFAF7"
                        BorderBrush="#55E5E7EB"
                        BorderThickness="0,1,0,0"
                        CornerRadius="0,0,24,24">
                    <Grid>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Left">
                            <Button Content="&#x5220;&#x9664;"
                                    Command="{Binding DeleteNoteCommand}"
                                    Style="{StaticResource SpotlightDangerActionButtonStyle}" />
                            <Button Content="{Binding NoteArchiveActionText}"
                                    Command="{Binding ArchiveNoteCommand}"
                                    Style="{StaticResource SpotlightActionButtonStyle}"
                                    Margin="8,0,0,0" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Visibility="{Binding IsNoteSpotlightPreviewing, Converter={StaticResource BooleanToVisibilityConverterEx}}">
                            <Button Content="&#x7F16;&#x8F91;"
                                    Command="{Binding EditSpotlightCommand}"
                                    Style="{StaticResource SpotlightPrimaryActionButtonStyle}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Visibility="{Binding IsNoteSpotlightEditing, Converter={StaticResource BooleanToVisibilityConverterEx}}">
                            <Button Content="&#x53D6;&#x6D88;"
                                    Command="{Binding CancelSpotlightEditCommand}"
                                    Style="{StaticResource SpotlightActionButtonStyle}"
                                    Margin="0,0,10,0" />
                            <Button Content="&#x4FDD;&#x5B58;"
                                    Command="{Binding SaveNoteCommand}"
                                    Style="{StaticResource SpotlightPrimaryActionButtonStyle}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        </Canvas>
    </Grid>
</UserControl>
