<UserControl x:Class="KanbanForOne.Controls.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <SolidColorBrush x:Key="WorkOptionPanelBrush" Color="#FAFAF8" />
        <SolidColorBrush x:Key="WorkOptionChipBrush" Color="#F0F3F0" />
        <SolidColorBrush x:Key="WorkOptionChipBorderBrush" Color="#DCE2DD" />
        <SolidColorBrush x:Key="WorkOptionAccentBrush" Color="#71877D" />
        <SolidColorBrush x:Key="WorkOptionAccentStrongBrush" Color="#34453E" />

        <Style x:Key="WorkOptionInputShellStyle" TargetType="Border">
            <Setter Property="Height" Value="38" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D7DDD9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource WorkOptionAccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WorkOptionTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="11,0,8,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style x:Key="WorkOptionAddButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="62" />
            <Setter Property="Margin" Value="0,3,3,3" />
            <Setter Property="Padding" Value="13,0" />
            <Setter Property="Background" Value="{StaticResource WorkOptionAccentStrongBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#465A51" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#27352F" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#9BB0A7" />
                                <Setter TargetName="ButtonChrome" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#E6E9E7" />
                                <Setter Property="Foreground" Value="#929A96" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WorkOptionRemoveButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Margin" Value="4,0,-3,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#78817C" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RemoveChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RemoveChrome" Property="Background" Value="#F7EDEC" />
                                <Setter Property="Foreground" Value="#93443E" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RemoveChrome" Property="Background" Value="#F0DEDC" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="RemoveChrome" Property="BorderBrush" Value="#A85A52" />
                                <Setter TargetName="RemoveChrome" Property="BorderThickness" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource MainContentBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32"
                        MaxWidth="760"
                        HorizontalAlignment="Left">
                <TextBlock Text="设置"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <TextBlock Text="当前版本使用本地 SQLite，并在 EXE 所在目录的 data/ 下保存数据。"
                           Margin="0,6,0,22"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" />

                <Border Padding="18"
                        CornerRadius="10"
                        Background="#FFFFFF"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="本地数据位置"
                                   FontSize="14"
                                   FontWeight="SemiBold" />

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="数据目录"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding DataDirectory}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </Grid>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="数据库"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding DatabasePath}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </Grid>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="附件目录"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding AttachmentDirectory}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </Grid>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="备份目录"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding BackupDirectory}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </Grid>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="人工时选项"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding WorkHourOptionsPath}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Padding="18"
                        Margin="0,16,0,0"
                        CornerRadius="10"
                        Background="#FFFFFF"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       Text="人工时下拉选项"
                                       FontSize="14"
                                       FontWeight="SemiBold" />
                            <Border Grid.Column="1"
                                    Padding="9,4"
                                    Background="#EFF4F1"
                                    BorderBrush="#D8E3DD"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <TextBlock Text="JSON 自动同步"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="#536C61" />
                            </Border>
                        </Grid>
                        <TextBlock Text="专业和工作内容保存在 JSON 配置中；人工时录入时输入的新值也会自动加入。"
                                   Margin="0,6,0,16"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Padding="14"
                                    Background="{StaticResource WorkOptionPanelBrush}"
                                    BorderBrush="#E1E4E1"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="28"
                                                Height="28"
                                                VerticalAlignment="Top"
                                                Background="#E9EFEB"
                                                CornerRadius="6">
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="#50665C"
                                                       Text="专" />
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="专业"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Margin="0,2,0,0"
                                                       Text="人工时所属的工程专业"
                                                       FontSize="10"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   VerticalAlignment="Center"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Text="{Binding WorkDisciplines.Count, StringFormat={}{0} 项}" />
                                    </Grid>

                                    <Border Margin="0,13,0,12"
                                            Style="{StaticResource WorkOptionInputShellStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="NewDisciplineTextBox"
                                                     AutomationProperties.Name="新增人工时专业选项"
                                                     Text="{Binding NewWorkDiscipline, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource WorkOptionTextBoxStyle}" />
                                            <TextBlock Margin="11,0,8,0"
                                                       VerticalAlignment="Center"
                                                       IsHitTestVisible="False"
                                                       FontSize="11"
                                                       Foreground="#9AA19D"
                                                       Text="输入新专业">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Text, ElementName=NewDisciplineTextBox}" Value="">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Button Grid.Column="1"
                                                    AutomationProperties.Name="添加人工时专业选项"
                                                    Content="添加"
                                                    Command="{Binding AddWorkDisciplineCommand}"
                                                    Style="{StaticResource WorkOptionAddButtonStyle}" />
                                        </Grid>
                                    </Border>

                                    <ItemsControl ItemsSource="{Binding WorkDisciplines}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,7,7"
                                                        Padding="9,3,5,3"
                                                        Background="{StaticResource WorkOptionChipBrush}"
                                                        BorderBrush="{StaticResource WorkOptionChipBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock VerticalAlignment="Center"
                                                                   FontSize="11"
                                                                   Foreground="#34423B"
                                                                   Text="{Binding}" />
                                                        <Button AutomationProperties.Name="{Binding StringFormat=移除专业选项 {0}}"
                                                                Command="{Binding DataContext.RemoveWorkDisciplineCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Content="×"
                                                                Style="{StaticResource WorkOptionRemoveButtonStyle}"
                                                                ToolTip="移除该专业选项" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Padding="14"
                                    Background="{StaticResource WorkOptionPanelBrush}"
                                    BorderBrush="#E1E4E1"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="28"
                                                Height="28"
                                                VerticalAlignment="Top"
                                                Background="#E9EFEB"
                                                CornerRadius="6">
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="#50665C"
                                                       Text="工" />
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="工作内容"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Margin="0,2,0,0"
                                                       Text="人工时对应的工作类型"
                                                       FontSize="10"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   VerticalAlignment="Center"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Text="{Binding WorkActivities.Count, StringFormat={}{0} 项}" />
                                    </Grid>

                                    <Border Margin="0,13,0,12"
                                            Style="{StaticResource WorkOptionInputShellStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="NewActivityTextBox"
                                                     AutomationProperties.Name="新增人工时工作内容选项"
                                                     Text="{Binding NewWorkActivity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource WorkOptionTextBoxStyle}" />
                                            <TextBlock Margin="11,0,8,0"
                                                       VerticalAlignment="Center"
                                                       IsHitTestVisible="False"
                                                       FontSize="11"
                                                       Foreground="#9AA19D"
                                                       Text="输入新工作内容">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Text, ElementName=NewActivityTextBox}" Value="">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Button Grid.Column="1"
                                                    AutomationProperties.Name="添加人工时工作内容选项"
                                                    Content="添加"
                                                    Command="{Binding AddWorkActivityCommand}"
                                                    Style="{StaticResource WorkOptionAddButtonStyle}" />
                                        </Grid>
                                    </Border>

                                    <ItemsControl ItemsSource="{Binding WorkActivities}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,7,7"
                                                        Padding="9,3,5,3"
                                                        Background="{StaticResource WorkOptionChipBrush}"
                                                        BorderBrush="{StaticResource WorkOptionChipBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="6">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock VerticalAlignment="Center"
                                                                   FontSize="11"
                                                                   Foreground="#34423B"
                                                                   Text="{Binding}" />
                                                        <Button AutomationProperties.Name="{Binding StringFormat=移除工作内容选项 {0}}"
                                                                Command="{Binding DataContext.RemoveWorkActivityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Content="×"
                                                                Style="{StaticResource WorkOptionRemoveButtonStyle}"
                                                                ToolTip="移除该工作内容选项" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBlock Margin="0,10,0,0"
                                   Text="移除选项不会影响已经保存的人工时记录。"
                                   FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <Border Padding="18"
                        Margin="0,16,0,0"
                        CornerRadius="10"
                        Background="#FFFDF7"
                        BorderBrush="#EFE3C5"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="当前策略"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="数据会自动生成在 EXE 所在目录的 data/ 下，便于随程序目录一起备份或迁移。"
                                   Margin="0,8,0,0"
                                   FontSize="12"
                                   LineHeight="18"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="备份页可创建包含数据库、附件和人工时选项 JSON 的 zip 包。"
                                   Margin="0,5,0,0"
                                   FontSize="12"
                                   LineHeight="18"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <Border Padding="18"
                        Margin="0,16,0,0"
                        CornerRadius="10"
                        Background="#FFFFFF"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="关于"
                                   FontSize="14"
                                   FontWeight="SemiBold" />

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="版本"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding AppVersion}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </Grid>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="版权"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding CopyrightText}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Padding="18"
                        Margin="0,16,0,0"
                        CornerRadius="10"
                        Background="#FFFFFF"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="版本日志"
                                       FontSize="14"
                                       FontWeight="SemiBold" />
                            <Border Grid.Column="1"
                                    Padding="8,3"
                                    CornerRadius="8"
                                    Background="#F3F5F7">
                                <TextBlock Text="{Binding AppVersion}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </Border>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding ReleaseNotes}"
                                      Margin="0,16,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="18" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Grid>
                                            <Rectangle Width="2"
                                                       HorizontalAlignment="Center"
                                                       Fill="#E5E7EB" />
                                            <Ellipse Width="8"
                                                     Height="8"
                                                     VerticalAlignment="Top"
                                                     HorizontalAlignment="Center"
                                                     Margin="0,5,0,0"
                                                     Fill="#BE185D" />
                                        </Grid>

                                        <StackPanel Grid.Column="1">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Version}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Date}"
                                                           Margin="10,1,0,0"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </StackPanel>

                                            <ItemsControl ItemsSource="{Binding Items}"
                                                          Margin="0,8,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="14" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Ellipse Width="4"
                                                                     Height="4"
                                                                     Margin="0,7,0,0"
                                                                     VerticalAlignment="Top"
                                                                     Fill="{StaticResource TextSecondaryBrush}" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding}"
                                                                       FontSize="12"
                                                                       LineHeight="18"
                                                                       TextWrapping="Wrap"
                                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
