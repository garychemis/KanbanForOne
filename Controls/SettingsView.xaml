<UserControl x:Class="KanbanForOne.Controls.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource MainContentBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32"
                        MaxWidth="760"
                        HorizontalAlignment="Left">
                <TextBlock Text="设置"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <TextBlock Text="当前版本使用本地 SQLite，并在 EXE 所在目录的 data/ 下保存数据。"
                           Margin="0,6,0,22"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" />

                <Border Padding="18"
                        CornerRadius="10"
                        Background="#FFFFFF"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="本地数据位置"
                                   FontSize="14"
                                   FontWeight="SemiBold" />

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="数据目录"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding DataDirectory}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </Grid>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="数据库"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding DatabasePath}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </Grid>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="附件目录"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding AttachmentDirectory}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </Grid>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="备份目录"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding BackupDirectory}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Padding="18"
                        Margin="0,16,0,0"
                        CornerRadius="10"
                        Background="#FFFDF7"
                        BorderBrush="#EFE3C5"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="当前策略"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="数据会自动生成在 EXE 所在目录的 data/ 下，便于随程序目录一起备份或迁移。"
                                   Margin="0,8,0,0"
                                   FontSize="12"
                                   LineHeight="18"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="备份页可创建包含 data/db/Kanban41.db 和 data/attachments/ 的 zip 包。"
                                   Margin="0,5,0,0"
                                   FontSize="12"
                                   LineHeight="18"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <Border Padding="18"
                        Margin="0,16,0,0"
                        CornerRadius="10"
                        Background="#FFFFFF"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="关于"
                                   FontSize="14"
                                   FontWeight="SemiBold" />

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="版本"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding AppVersion}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </Grid>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="版权"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding CopyrightText}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Padding="18"
                        Margin="0,16,0,0"
                        CornerRadius="10"
                        Background="#FFFFFF"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="版本日志"
                                       FontSize="14"
                                       FontWeight="SemiBold" />
                            <Border Grid.Column="1"
                                    Padding="8,3"
                                    CornerRadius="8"
                                    Background="#F3F5F7">
                                <TextBlock Text="{Binding AppVersion}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </Border>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding ReleaseNotes}"
                                      Margin="0,16,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="18" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Grid>
                                            <Rectangle Width="2"
                                                       HorizontalAlignment="Center"
                                                       Fill="#E5E7EB" />
                                            <Ellipse Width="8"
                                                     Height="8"
                                                     VerticalAlignment="Top"
                                                     HorizontalAlignment="Center"
                                                     Margin="0,5,0,0"
                                                     Fill="#BE185D" />
                                        </Grid>

                                        <StackPanel Grid.Column="1">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Version}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Date}"
                                                           Margin="10,1,0,0"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </StackPanel>

                                            <ItemsControl ItemsSource="{Binding Items}"
                                                          Margin="0,8,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="14" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Ellipse Width="4"
                                                                     Height="4"
                                                                     Margin="0,7,0,0"
                                                                     VerticalAlignment="Top"
                                                                     Fill="{StaticResource TextSecondaryBrush}" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding}"
                                                                       FontSize="12"
                                                                       LineHeight="18"
                                                                       TextWrapping="Wrap"
                                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
