<UserControl x:Class="KanbanForOne.Controls.TagChipEditorControl"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="26">
    <Border x:Name="Container"
            Padding="0"
            CornerRadius="4"
            Background="{Binding EditorBackground, ElementName=Root}"
            BorderBrush="{Binding EditorBorderBrush, ElementName=Root}"
            BorderThickness="1">
        <WrapPanel x:Name="TagsPanel"
                   VerticalAlignment="Center">
            <TextBox x:Name="InputBox"
                     MinWidth="60"
                     MaxWidth="180"
                     BorderThickness="0"
                     Background="Transparent"
                     Foreground="{Binding ChipForeground, ElementName=Root}"
                     FontSize="11"
                     Padding="3,3"
                     VerticalContentAlignment="Center"
                     KeyDown="OnInputKeyDown"
                     LostKeyboardFocus="OnInputLostKeyboardFocus" />
        </WrapPanel>
    </Border>
</UserControl>
