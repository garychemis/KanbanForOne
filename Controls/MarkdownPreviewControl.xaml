<UserControl x:Class="KanbanForOne.Controls.MarkdownPreviewControl"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False"
             IsHitTestVisible="False">
    <TextBlock x:Name="PreviewText"
               FontSize="{Binding PreviewFontSize, ElementName=Root}"
               Foreground="{Binding PreviewForeground, ElementName=Root}"
               LineHeight="{Binding PreviewLineHeight, ElementName=Root}"
               MaxHeight="{Binding PreviewMaxHeight, ElementName=Root}"
               TextTrimming="CharacterEllipsis"
               TextWrapping="Wrap" />
</UserControl>
