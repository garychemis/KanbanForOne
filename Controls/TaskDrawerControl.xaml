<UserControl x:Class="KanbanForOne.Controls.TaskDrawerControl"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:KanbanForOne.Controls">
    <Border Style="{StaticResource DrawerPanelStyle}">
    <Grid Style="{StaticResource DrawerRootStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource DrawerHeaderStyle}">
            <Grid Focusable="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Focusable="False">
                    <Border Padding="12,5"
                            CornerRadius="999"
                            Background="{Binding TaskStatusDraft, Converter={StaticResource TaskStatusBackgroundConverter}}">
                        <TextBlock Text="{Binding TaskStatusDraft, Converter={StaticResource TaskStatusNameConverter}}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding TaskStatusDraft, Converter={StaticResource TaskStatusBrushConverter}}" />
                    </Border>

                    <Border Margin="8,0,0,0"
                            Padding="10,5"
                            CornerRadius="999"
                            Background="#73FFFFFF"
                            Visibility="{Binding HasUnsavedTaskChanges, Converter={StaticResource BooleanToVisibilityConverterEx}}">
                        <TextBlock Text="&#x672A;&#x4FDD;&#x5B58;"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </Border>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="&#xD7;"
                        Command="{Binding CloseDrawerCommand}"
                        Style="{StaticResource DrawerCloseButtonStyle}"
                        ToolTip="&#x5173;&#x95ED;" />

                <TextBox Grid.Row="1"
                         Grid.ColumnSpan="2"
                         Margin="0,18,42,0"
                         Text="{Binding TaskTitleDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DrawerTitleTextBoxStyle}" />

                <TextBlock Grid.Row="2"
                           Grid.ColumnSpan="2"
                           Margin="0,8,0,0"
                           FontSize="12"
                           Foreground="{StaticResource DrawerMutedBrush}">
                    <Run Text="&#x66F4;&#x65B0;&#x4E8E; " />
                    <Run Text="{Binding SelectedTask.UpdatedAt, ElementName=Root, StringFormat={}{0:yyyy/M/d HH:mm}}" />
                </TextBlock>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Padding="32,24,32,28"
                      Focusable="False"
                      FocusVisualStyle="{x:Null}"
                      BorderThickness="0"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Focusable="False">
                <StackPanel Style="{StaticResource BorderlessDrawerSectionStyle}">
                    <TextBlock Text="&#x72B6;&#x6001;"
                               Style="{StaticResource BorderlessDrawerSectionTitleStyle}" />
                    <WrapPanel Focusable="False">
                        <RadioButton Content="&#x5F85;&#x529E;"
                                     IsChecked="{Binding TaskStatusDraft, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Todo, Mode=TwoWay}"
                                     Style="{StaticResource BorderlessChipButtonStyle}" />
                        <RadioButton Content="&#x8FDB;&#x884C;&#x4E2D;"
                                     IsChecked="{Binding TaskStatusDraft, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Doing, Mode=TwoWay}"
                                     Style="{StaticResource BorderlessChipButtonStyle}" />
                        <RadioButton Content="&#x5361;&#x4F4F;"
                                     IsChecked="{Binding TaskStatusDraft, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Blocked, Mode=TwoWay}"
                                     Style="{StaticResource BorderlessChipButtonStyle}" />
                        <RadioButton Content="&#x5B8C;&#x6210;"
                                     IsChecked="{Binding TaskStatusDraft, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Done, Mode=TwoWay}"
                                     Style="{StaticResource BorderlessChipButtonStyle}" />
                    </WrapPanel>
                </StackPanel>

                <StackPanel Style="{StaticResource BorderlessDrawerSectionStyle}">
                    <TextBlock Text="&#x4F18;&#x5148;&#x7EA7;"
                               Style="{StaticResource BorderlessDrawerSectionTitleStyle}" />
                    <WrapPanel Focusable="False">
                        <RadioButton IsChecked="{Binding TaskPriorityDraft, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=High, Mode=TwoWay}"
                                     Style="{StaticResource BorderlessChipButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8"
                                         Height="8"
                                         Fill="#DC2626"
                                         Margin="0,0,8,0"
                                         VerticalAlignment="Center" />
                                <TextBlock Text="&#x9AD8;" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton IsChecked="{Binding TaskPriorityDraft, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Medium, Mode=TwoWay}"
                                     Style="{StaticResource BorderlessChipButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8"
                                         Height="8"
                                         Fill="#FACC15"
                                         Margin="0,0,8,0"
                                         VerticalAlignment="Center" />
                                <TextBlock Text="&#x4E2D;" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton IsChecked="{Binding TaskPriorityDraft, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Low, Mode=TwoWay}"
                                     Style="{StaticResource BorderlessChipButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8"
                                         Height="8"
                                         Fill="#60A5FA"
                                         Margin="0,0,8,0"
                                         VerticalAlignment="Center" />
                                <TextBlock Text="&#x4F4E;" />
                            </StackPanel>
                        </RadioButton>
                    </WrapPanel>
                </StackPanel>

                <StackPanel Style="{StaticResource BorderlessDrawerSectionStyle}">
                    <TextBlock Text="&#x4EFB;&#x52A1;&#x65E5;&#x671F;"
                               Style="{StaticResource BorderlessDrawerSectionTitleStyle}" />
                    <Grid Focusable="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource BorderlessDateCardStyle}">
                            <Grid Focusable="False">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE787;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="15"
                                           Foreground="{StaticResource DrawerMutedBrush}"
                                           VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="&#x8D77;&#x59CB;"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource DrawerMutedBrush}" />
                                    <DatePicker SelectedDate="{Binding TaskStartDateDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Margin="0,5,0,0"
                                                Style="{StaticResource DrawerDatePickerStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                Style="{StaticResource BorderlessDateCardStyle}">
                            <Grid Focusable="False">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE787;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="15"
                                           Foreground="{StaticResource DrawerMutedBrush}"
                                           VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="&#x622A;&#x6B62;"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource DrawerMutedBrush}" />
                                    <DatePicker SelectedDate="{Binding TaskEndDateDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Margin="0,5,0,0"
                                                Style="{StaticResource DrawerDatePickerStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </StackPanel>

                <StackPanel Style="{StaticResource BorderlessDrawerSectionStyle}">
                    <Grid Margin="0,0,0,12"
                          Focusable="False">
                        <TextBlock Text="&#x6807;&#x7B7E;"
                                   Style="{StaticResource BorderlessDrawerSectionTitleStyle}" />
                        <Button Content="+ &#x6DFB;&#x52A0;"
                                Click="OnAddTagClick"
                                Style="{StaticResource DrawerSecondaryButtonStyle}"
                                Height="30"
                                MinWidth="66"
                                Padding="10,0"
                                FontSize="12"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                ToolTip="&#x6DFB;&#x52A0;&#x6807;&#x7B7E;" />
                    </Grid>
                    <controls:TagChipEditorControl x:Name="TaskTagEditor"
                                                   Text="{Binding TaskTagsDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                   EditorBackground="Transparent"
                                                   EditorBorderBrush="Transparent"
                                                   ChipBackground="#8CFFFFFF"
                                                   ChipForeground="#3A5266" />
                </StackPanel>

                <StackPanel Style="{StaticResource BorderlessDrawerSectionStyle}">
                    <TextBlock Text="&#x63CF;&#x8FF0;"
                               Style="{StaticResource BorderlessDrawerSectionTitleStyle}" />
                    <controls:MarkdownEditorControl Text="{Binding TaskDescriptionDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Style="{StaticResource DrawerDescriptionEditorStyle}" />
                </StackPanel>

                <StackPanel Style="{StaticResource BorderlessDrawerSectionStyle}"
                            Margin="0">
                    <Grid Margin="0,0,0,12"
                          Focusable="False">
                        <TextBlock Text="{Binding SelectedTask.AttachmentCount, ElementName=Root, StringFormat=&#x9644;&#x4EF6; {0}}"
                                   Style="{StaticResource BorderlessDrawerSectionTitleStyle}" />
                        <Button Content="+ &#x6DFB;&#x52A0;"
                                Command="{Binding PickFilesCommand}"
                                CommandParameter="{Binding SelectedTask, ElementName=Root}"
                                Style="{StaticResource DrawerSecondaryButtonStyle}"
                                Height="30"
                                MinWidth="66"
                                Padding="10,0"
                                FontSize="12"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                ToolTip="&#x6DFB;&#x52A0;&#x9644;&#x4EF6;" />
                    </Grid>
                    <controls:AttachmentDropZoneControl Owner="{Binding SelectedTask, ElementName=Root}"
                                                        AttachFilesCommand="{Binding AttachFilesCommand}"
                                                        TitleText="&#x62D6;&#x62FD;&#x6587;&#x4EF6;&#x5230;&#x8FD9;&#x91CC;&#x4E0A;&#x4F20;"
                                                        HelperText="&#x652F;&#x6301;&#x6587;&#x6863;&#x3001;&#x56FE;&#x7247;&#x3001;&#x538B;&#x7F29;&#x5305;&#x7B49;&#x9644;&#x4EF6;"
                                                        DropHintText="&#x91CA;&#x653E;&#x6587;&#x4EF6;&#x4EE5;&#x4FDD;&#x5B58;&#x4E3A;&#x9644;&#x4EF6;"
                                                        Style="{StaticResource BorderlessAttachmentDropZoneStyle}" />
                    <controls:AttachmentListControl ItemsSource="{Binding SelectedTask.Attachments, ElementName=Root}"
                                                    OpenCommand="{Binding OpenAttachmentCommand}"
                                                    RevealCommand="{Binding RevealAttachmentCommand}"
                                                    DeleteCommand="{Binding DeleteAttachmentCommand}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Style="{StaticResource DrawerFooterStyle}">
            <Grid Focusable="False">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Content="&#x5220;&#x9664;"
                        Command="{Binding DeleteTaskCommand}"
                        Style="{StaticResource DrawerDangerButtonStyle}" />

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal">
                    <Button Content="&#x53D6;&#x6D88;"
                            Command="{Binding CloseDrawerCommand}"
                            Style="{StaticResource DrawerSecondaryButtonStyle}"
                            Margin="0,0,10,0" />
                    <Button Content="&#x4FDD;&#x5B58;"
                            Command="{Binding SaveTaskCommand}"
                            Style="{StaticResource DrawerPrimaryButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
    </Border>
</UserControl>
