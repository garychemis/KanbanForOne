<UserControl x:Class="KanbanForOne.Controls.BackupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource MainContentBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32"
                        MaxWidth="760"
                        HorizontalAlignment="Left">
            <TextBlock Text="数据备份"
                       FontSize="20"
                       FontWeight="SemiBold" />
            <TextBlock Text="备份会包含 Kanban41.db 和 attachments/，生成 zip 文件保存在 EXE 所在目录的 backups/。"
                       Margin="0,6,0,22"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}" />

            <Border Padding="18"
                    CornerRadius="10"
                    Background="#FFFFFF"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="当前本地数据"
                               FontSize="14"
                               FontWeight="SemiBold" />

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="数据目录"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding DataDirectory}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                    </Grid>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="数据库"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding DatabasePath}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                    </Grid>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="附件目录"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding AttachmentDirectory}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                    </Grid>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="备份目录"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding BackupDirectory}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                    </Grid>

                    <StackPanel Orientation="Horizontal"
                                Margin="0,20,0,0">
                        <Button Content="创建备份"
                                Command="{Binding CreateBackupCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                MinWidth="104" />
                        <Button Content="恢复备份"
                                Command="{Binding RestoreBackupCommand}"
                                Style="{StaticResource IconButtonStyle}"
                                MinWidth="104"
                                Margin="10,0,0,0" />
                    </StackPanel>

                    <TextBlock Text="恢复会覆盖当前 Kanban41.db 和 attachments/，执行前会自动创建恢复前保护备份。"
                               Margin="0,10,0,0"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </Border>

            <Border Padding="14"
                    Margin="0,16,0,0"
                    CornerRadius="10"
                    Background="#EDF7F0"
                    BorderBrush="#CDE7D4"
                    BorderThickness="1"
                    Visibility="{Binding HasLastBackup, Converter={StaticResource BooleanToVisibilityConverterEx}}">
                <StackPanel>
                    <TextBlock Text="最近备份"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#2F6B3F" />
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="备份文件"
                                   FontSize="12"
                                   Foreground="#2F6B3F" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LastBackupPath}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Foreground="#2F6B3F" />
                    </Grid>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="创建时间"
                                   FontSize="12"
                                   Foreground="#2F6B3F" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LastBackupCreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                   FontSize="12"
                                   Foreground="#2F6B3F" />
                    </Grid>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="附件文件"
                                   FontSize="12"
                                   Foreground="#2F6B3F" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LastBackupAttachmentCount, StringFormat={}{0} 个}"
                                   FontSize="12"
                                   Foreground="#2F6B3F" />
                    </Grid>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="压缩包大小"
                                   FontSize="12"
                                   Foreground="#2F6B3F" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LastBackupSizeBytes, Converter={StaticResource AttachmentSizeConverter}}"
                                   FontSize="12"
                                   Foreground="#2F6B3F" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Padding="14"
                    Margin="0,16,0,0"
                    CornerRadius="10"
                    Background="#FFF9DB"
                    BorderBrush="#F1E5A8"
                    BorderThickness="1"
                    Visibility="{Binding HasLastRestore, Converter={StaticResource BooleanToVisibilityConverterEx}}">
                <StackPanel>
                    <TextBlock Text="最近恢复"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#6B5B2E" />
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="来源备份"
                                   FontSize="12"
                                   Foreground="#6B5B2E" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LastRestoreSourcePath}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Foreground="#6B5B2E" />
                    </Grid>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="保护备份"
                                   FontSize="12"
                                   Foreground="#6B5B2E" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LastRestoreProtectiveBackupPath}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Foreground="#6B5B2E" />
                    </Grid>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="恢复时间"
                                   FontSize="12"
                                   Foreground="#6B5B2E" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LastRestoreAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                   FontSize="12"
                                   Foreground="#6B5B2E" />
                    </Grid>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="附件文件"
                                   FontSize="12"
                                   Foreground="#6B5B2E" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LastRestoreAttachmentCount, StringFormat={}{0} 个}"
                                   FontSize="12"
                                   Foreground="#6B5B2E" />
                    </Grid>
                </StackPanel>
            </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
