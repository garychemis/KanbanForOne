<UserControl x:Class="KanbanForOne.Controls.CalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:KanbanForOne.Controls"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
    <UserControl.Resources>
        <Style x:Key="CalendarModeButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="54" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Border.Background>
                                <MultiBinding Converter="{StaticResource FilterSelectedBackgroundConverter}"
                                              ConverterParameter="#DDE3EB|#00FFFFFF">
                                    <Binding Path="DataContext.CalendarViewMode"
                                             RelativeSource="{RelativeSource TemplatedParent}" />
                                    <Binding Path="CommandParameter"
                                             RelativeSource="{RelativeSource TemplatedParent}" />
                                </MultiBinding>
                            </Border.Background>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.82" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CalendarDayBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="MinHeight" Value="118" />
            <Setter Property="Padding" Value="9" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D8DADF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                    <Setter Property="Background" Value="#F2F3F5" />
                    <Setter Property="Opacity" Value="0.72" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsToday}" Value="True">
                    <Setter Property="BorderBrush" Value="#2563EB" />
                    <Setter Property="BorderThickness" Value="1.5" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#F8FAFC" />
                    <Setter Property="BorderBrush" Value="#111827" />
                    <Setter Property="BorderThickness" Value="2" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="CalendarChipTemplate">
            <Border Margin="0,0,0,4"
                    Padding="7,3"
                    CornerRadius="5"
                    Background="{Binding Status, Converter={StaticResource TaskStatusBackgroundConverter}}"
                    BorderBrush="{Binding Status, Converter={StaticResource TaskStatusBrushConverter}}"
                    BorderThickness="0,0,0,2"
                    IsHitTestVisible="False"
                    ToolTip="{Binding Task.DateRangeDisplay}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding RangeMarker}"
                               Width="14"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{Binding Status, Converter={StaticResource TaskStatusBrushConverter}}"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Title}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="CalendarDayTemplate">
            <Border Style="{StaticResource CalendarDayBorderStyle}"
                    AllowDrop="True"
                    MouseLeftButtonDown="OnDayPreviewMouseLeftButtonDown"
                    DragEnter="OnDayDragOver"
                    DragOver="OnDayDragOver"
                    Drop="OnDayDrop">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <TextBlock Text="{Binding DayNumber}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <Border HorizontalAlignment="Right"
                                Padding="6,2"
                                CornerRadius="5"
                                Background="#DBEAFE"
                                Visibility="{Binding IsToday, Converter={StaticResource BooleanToVisibilityConverterEx}}">
                            <TextBlock Text="今天"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#1D4ED8" />
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="1"
                                Margin="0,8,0,0">
                        <ItemsControl ItemsSource="{Binding VisibleTaskChips}"
                                      ItemTemplate="{StaticResource CalendarChipTemplate}" />
                        <Border Padding="6,2"
                                CornerRadius="5"
                                Background="#EEF1F4"
                                HorizontalAlignment="Left"
                                Visibility="{Binding HasOverflow, Converter={StaticResource BooleanToVisibilityConverterEx}}">
                            <TextBlock Text="{Binding OverflowText}"
                                       FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="CalendarTaskListTemplate">
            <Border Margin="0,0,0,8"
                    Padding="10"
                    CornerRadius="7"
                    Background="{Binding Status, Converter={StaticResource TaskStatusBackgroundConverter}}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    Cursor="Hand"
                    PreviewMouseLeftButtonDown="OnTaskPreviewMouseLeftButtonDown"
                    MouseMove="OnTaskMouseMove"
                    MouseLeftButtonUp="OnTaskMouseLeftButtonUp">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding Title}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding DateRangeDisplay}"
                                   Margin="0,3,0,0"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Padding="7,3"
                            CornerRadius="5"
                            Background="#FFFFFF"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding Status, Converter={StaticResource TaskStatusNameConverter}}"
                                   FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="CalendarWorkHourListTemplate">
            <Button Command="{Binding DataContext.OpenWorkHourCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding}"
                    Style="{StaticResource ListCardButtonStyle}"
                    Margin="0,0,0,8">
                <Border Padding="10"
                        CornerRadius="7"
                        BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="Background" Value="#F5F6F4" />
                            <Setter Property="BorderBrush" Value="#D5DBD8" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}"
                                             Value="True">
                                    <Setter Property="Background" Value="#F0F3F1" />
                                    <Setter Property="BorderBrush" Value="#B9C3BF" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding ProjectNumber}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#2F3A36"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="11"
                                       Foreground="#68736F">
                                <Run Text="{Binding Discipline, Mode=OneWay}" />
                                <Run Text=" · " />
                                <Run Text="{Binding WorkActivity, Mode=OneWay}" />
                            </TextBlock>
                            <TextBlock Text="{Binding Remark}"
                                       Margin="0,4,0,0"
                                       FontSize="10"
                                       Foreground="#7B8581"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{Binding HasRemark, Converter={StaticResource BooleanToVisibilityConverterEx}}" />
                        </StackPanel>
                        <Border Grid.Column="1"
                                Margin="8,0,0,0"
                                Padding="7,3"
                                CornerRadius="5"
                                Background="#FBFCFB"
                                BorderBrush="#D5DBD8"
                                BorderThickness="1"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding HoursDisplay}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#4F605A" />
                        </Border>
                    </Grid>
                </Border>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="CalendarListTemplate">
            <Border Margin="0,0,0,10"
                    Padding="14"
                    CornerRadius="8"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    Background="{Binding Status, Converter={StaticResource TaskStatusBackgroundConverter}}"
                    Cursor="Hand"
                    PreviewMouseLeftButtonDown="OnTaskPreviewMouseLeftButtonDown"
                    MouseMove="OnTaskMouseMove"
                    MouseLeftButtonUp="OnTaskMouseLeftButtonUp">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding DateRangeDisplay}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="任务日期"
                                   Margin="0,4,0,0"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Margin="14,0,22,0">
                        <TextBlock Text="{Binding Title}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" />
                        <controls:MarkdownPreviewControl Markdown="{Binding Description}"
                                                         Margin="0,6,0,0"
                                                         PreviewFontSize="12"
                                                         PreviewForeground="{StaticResource TextSecondaryBrush}"
                                                         PreviewLineHeight="18"
                                                         PreviewMaxHeight="38" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                MinWidth="90"
                                HorizontalAlignment="Right">
                        <TextBlock Text="{Binding Status, Converter={StaticResource TaskStatusNameConverter}}"
                                   FontSize="11"
                                   TextAlignment="Right"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding Priority, Converter={StaticResource TaskPriorityNameConverter}, StringFormat=优先级 {0}}"
                                   Margin="0,8,0,0"
                                   FontSize="11"
                                   TextAlignment="Right"
                                   Foreground="{Binding Priority, Converter={StaticResource TaskPriorityBrushConverter}}" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{StaticResource MainContentBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="28,22,28,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="日历"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding CalendarTaskCount, Mode=OneWay, StringFormat=有日期任务 {0}}"
                           Margin="0,5,0,0"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Content="月"
                        Command="{Binding SetCalendarViewModeCommand}"
                        CommandParameter="Month"
                        Style="{StaticResource CalendarModeButtonStyle}" />
                <Button Content="列表"
                        Command="{Binding SetCalendarViewModeCommand}"
                        CommandParameter="List"
                        Style="{StaticResource CalendarModeButtonStyle}"
                        Margin="6,0,14,0" />
                <Button Content="‹"
                        Command="{Binding PreviousCalendarMonthCommand}"
                        Style="{StaticResource IconButtonStyle}"
                        Width="32"
                        Height="30"
                        ToolTip="上个月" />
                <Border Padding="12,0"
                        MinWidth="112"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding CalendarMonthTitle}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                </Border>
                <Button Content="›"
                        Command="{Binding NextCalendarMonthCommand}"
                        Style="{StaticResource IconButtonStyle}"
                        Width="32"
                        Height="30"
                        ToolTip="下个月" />
                <Button Content="今天"
                        Command="{Binding GoToTodayCommand}"
                        Style="{StaticResource IconButtonStyle}"
                        Height="30"
                        MinWidth="52"
                        Margin="8,0,0,0" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1"
              Margin="28,0,28,24">
            <Grid Visibility="{Binding IsCalendarMonthMode, Converter={StaticResource BooleanToVisibilityConverterEx}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <ItemsControl ItemsSource="{Binding CalendarWeekdayHeaders}"
                                  Margin="0,0,0,8">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <primitives:UniformGrid Columns="7" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextAlignment="Center" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl Grid.Row="1"
                                  ItemsSource="{Binding CalendarDays}"
                                  ItemTemplate="{StaticResource CalendarDayTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <primitives:UniformGrid Columns="7"
                                                        Rows="6" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </Grid>

                <Border Grid.Column="2"
                        Padding="14"
                        CornerRadius="8"
                        Background="#FFFFFF"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="4*" />
                            <RowDefinition Height="1" />
                            <RowDefinition Height="5*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding SelectedCalendarDateDisplay}"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding SelectedCalendarTaskCount, StringFormat=当天任务 {0}}"
                                       Margin="0,4,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,12,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="任务"
                                       Margin="0,0,0,7"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <Grid>
                                    <ItemsControl ItemsSource="{Binding SelectedCalendarTasks}"
                                                  ItemTemplate="{StaticResource CalendarTaskListTemplate}"
                                                  Visibility="{Binding HasSelectedCalendarTasks, Converter={StaticResource BooleanToVisibilityConverterEx}}" />
                                    <controls:EmptyStateControl Title="当天暂无任务"
                                                                Message="双击日历格可快速创建任务。"
                                                                Visibility="{Binding HasSelectedCalendarTasks, Converter={StaticResource BooleanToVisibilityConverterEx}, ConverterParameter=Invert}" />
                                </Grid>
                            </ScrollViewer>
                        </Grid>

                        <Border Grid.Row="2" Background="#E2E8F0" />

                        <Grid Grid.Row="3" Margin="0,10,0,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Margin="0,0,0,7">
                                <TextBlock Text="人工时"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock HorizontalAlignment="Right"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}">
                                    <Run Text="{Binding SelectedCalendarWorkHourCount, Mode=OneWay}" />
                                    <Run Text=" 条 · " />
                                    <Run Text="{Binding SelectedCalendarWorkHourTotalDisplay, Mode=OneWay}" />
                                </TextBlock>
                            </Grid>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <Grid>
                                    <ItemsControl ItemsSource="{Binding SelectedCalendarWorkHours}"
                                                  ItemTemplate="{StaticResource CalendarWorkHourListTemplate}"
                                                  Visibility="{Binding HasSelectedCalendarWorkHours, Converter={StaticResource BooleanToVisibilityConverterEx}}" />
                                    <controls:EmptyStateControl Title="当天暂无人工时"
                                                                Message="点击下方按钮添加记录。"
                                                                Visibility="{Binding HasSelectedCalendarWorkHours, Converter={StaticResource BooleanToVisibilityConverterEx}, ConverterParameter=Invert}" />
                                </Grid>
                            </ScrollViewer>
                        </Grid>

                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Content="+ 新建任务"
                                    Command="{Binding CreateTaskForCalendarDateCommand}"
                                    CommandParameter="{Binding SelectedCalendarDate}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    HorizontalAlignment="Stretch" />
                            <Button Grid.Column="2"
                                    Content="+ 添加人工时"
                                    Command="{Binding AddWorkHourCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    HorizontalAlignment="Stretch" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Grid Visibility="{Binding IsCalendarListMode, Converter={StaticResource BooleanToVisibilityConverterEx}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding HasCalendarTasks, Converter={StaticResource BooleanToVisibilityConverterEx}}">
                    <ItemsControl ItemsSource="{Binding CalendarTasks}"
                                  ItemTemplate="{StaticResource CalendarListTemplate}" />
                </ScrollViewer>

                <controls:EmptyStateControl Title="暂无有日期任务"
                                            Message="给任务设置起始日期或截止日期后，会出现在这里。"
                                            VerticalAlignment="Top"
                                            Visibility="{Binding HasCalendarTasks, Converter={StaticResource BooleanToVisibilityConverterEx}, ConverterParameter=Invert}" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>
