<UserControl x:Class="KanbanForOne.Controls.CalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:KanbanForOne.Controls">
    <UserControl.Resources>
        <DataTemplate x:Key="TagChipTemplate">
            <Border Padding="8,3"
                    Margin="0,0,6,0"
                    CornerRadius="8"
                    Background="#F1F3F5">
                <TextBlock Text="{Binding}"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="CalendarTaskTemplate">
            <Button Style="{StaticResource ListCardButtonStyle}"
                    Command="{Binding DataContext.OpenTaskCommand, RelativeSource={RelativeSource AncestorType=controls:CalendarView}}"
                    CommandParameter="{Binding}">
                <Border Margin="0,0,0,12"
                        Padding="16"
                        CornerRadius="10"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        Background="{Binding Status, Converter={StaticResource TaskStatusBackgroundConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding DateRangeDisplay, Mode=OneWay}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="任务日期"
                                       Margin="0,4,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Margin="12,0,24,0">
                            <TextBlock Text="{Binding Title}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Description}"
                                       Margin="0,6,0,0"
                                       FontSize="12"
                                       LineHeight="18"
                                       MaxHeight="38"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <ItemsControl ItemsSource="{Binding Tags}"
                                          ItemTemplate="{StaticResource TagChipTemplate}"
                                          Margin="0,10,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    MinWidth="96"
                                    HorizontalAlignment="Right">
                            <Border Padding="9,4"
                                    CornerRadius="8"
                                    Background="#FFFFFF"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    HorizontalAlignment="Right">
                                <TextBlock Text="{Binding Status, Converter={StaticResource TaskStatusNameConverter}}"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </Border>
                            <TextBlock Text="{Binding Priority, Converter={StaticResource TaskPriorityNameConverter}, StringFormat=优先级 {0}}"
                                       Margin="0,8,0,0"
                                       FontSize="11"
                                       TextAlignment="Right"
                                       Foreground="{Binding Priority, Converter={StaticResource TaskPriorityBrushConverter}}" />
                            <TextBlock Text="{Binding AttachmentCount, StringFormat=附件 {0}}"
                                       Margin="0,4,0,0"
                                       FontSize="11"
                                       TextAlignment="Right"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Button>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{StaticResource MainContentBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="32,28,32,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="日历"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding CalendarTaskCount, Mode=OneWay, StringFormat=有日期任务 {0}}"
                           Margin="0,5,0,0"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </StackPanel>

            <Border Grid.Column="1"
                    Padding="12,7"
                    CornerRadius="10"
                    Background="#FFFFFF"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    VerticalAlignment="Center">
                <TextBlock Text="按起始日期升序"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </Border>
        </Grid>

        <Grid Grid.Row="1"
              Margin="32,0,32,28">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding CalendarTasks, Converter={StaticResource CollectionEmptyToVisibilityConverter}, ConverterParameter=Invert}">
                <ItemsControl ItemsSource="{Binding CalendarTasks}"
                              ItemTemplate="{StaticResource CalendarTaskTemplate}" />
            </ScrollViewer>

            <controls:EmptyStateControl Title="暂无有日期任务"
                                        Message="给任务设置起始日期和终止日期后，会出现在这里。"
                                        VerticalAlignment="Top"
                                        Visibility="{Binding CalendarTasks, Converter={StaticResource CollectionEmptyToVisibilityConverter}}" />
        </Grid>
    </Grid>
</UserControl>
