<UserControl x:Class="KanbanForOne.Controls.BoardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:KanbanForOne.Controls"
             xmlns:models="clr-namespace:KanbanForOne.Models">
    <UserControl.Resources>
        <DataTemplate x:Key="TaskCardTemplate">
            <controls:TaskCardControl OpenCommand="{Binding DataContext.OpenTaskCommand, RelativeSource={RelativeSource AncestorType=controls:BoardView}}"
                                      AttachFilesCommand="{Binding DataContext.AttachFilesCommand, RelativeSource={RelativeSource AncestorType=controls:BoardView}}" />
        </DataTemplate>

        <DataTemplate x:Key="NoteCardTemplate">
            <controls:NoteCardControl OpenCommand="{Binding DataContext.OpenNoteCommand, RelativeSource={RelativeSource AncestorType=controls:BoardView}}"
                                      AttachFilesCommand="{Binding DataContext.AttachFilesCommand, RelativeSource={RelativeSource AncestorType=controls:BoardView}}" />
        </DataTemplate>

        <Style x:Key="ArchivePickerButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="190" />
            <Setter Property="Padding" Value="13,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#CBD5E1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#EEF1F4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource MainContentBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Visibility="{Binding IsArchiveFilter, Converter={StaticResource BooleanToVisibilityConverterEx}}"
                Background="#F6F7F8"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="归档分区"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" />

                    <Button Grid.Column="1"
                            Command="{Binding OpenArchiveSectionPickerCommand}"
                            Style="{StaticResource ArchivePickerButtonStyle}"
                            Margin="12,0,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding ArchiveSectionSelectorText}"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1"
                                       Text="&#x2304;"
                                       Margin="12,0,0,2"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </Grid>
                    </Button>

                    <TextBlock Grid.Column="3"
                               Text="{Binding ArchiveSectionSelectorHint}"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </Grid>

                <DockPanel LastChildFill="True"
                           Visibility="Collapsed">
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Margin="12,0,0,0">
                    <TextBox Text="{Binding NewArchiveSectionName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Width="140"
                             Height="32"
                             Padding="10,6"
                             BorderBrush="{StaticResource BorderBrushSoft}"
                             BorderThickness="1"
                             Background="#FFFFFF"
                             VerticalContentAlignment="Center" />
                    <Button Content="新建"
                            Command="{Binding CreateArchiveSectionCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            MinWidth="60"
                            Height="32"
                            Margin="8,0,0,0" />
                </StackPanel>

                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding ArchiveSections}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.SelectArchiveSectionCommand, RelativeSource={RelativeSource AncestorType=controls:BoardView}}"
                                        CommandParameter="{Binding}"
                                        MinWidth="88"
                                        Height="32"
                                        Padding="12,0"
                                        Margin="0,0,8,0"
                                        BorderThickness="1"
                                        Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="{x:Type Button}">
                                            <Setter Property="Background" Value="#FFFFFF" />
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type Button}">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="8">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#EEF1F4" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="#212529" />
                                                    <Setter Property="BorderBrush" Value="#212529" />
                                                    <Setter Property="Foreground" Value="#FFFFFF" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        <TextBlock Text="{Binding TotalCount, StringFormat={} {0}}"
                                                   Margin="6,0,0,0"
                                                   FontSize="12"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                </DockPanel>
            </Grid>
        </Border>

        <ScrollViewer x:Name="BoardScrollViewer"
                      Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      Padding="16,28,16,28">
            <StackPanel Orientation="Horizontal">
                <controls:KanbanColumnControl Width="240"
                                              MinHeight="{Binding ActualHeight, ElementName=BoardScrollViewer}"
                                              Title="待办"
                                              Subtitle="计划中但尚未开始"
                                              ColumnKind="{x:Static models:KanbanColumnKind.Todo}"
                                              ItemsSource="{Binding TodoTasks}"
                                              ItemTemplate="{StaticResource TaskCardTemplate}"
                                              AddCommand="{Binding CreateTaskCommand}"
                                              AddCommandParameter="{x:Static models:KanbanColumnKind.Todo}"
                                              DropCommand="{Binding MoveCardCommand}"
                                              Margin="0,0,12,0" />

                <controls:KanbanColumnControl Width="240"
                                              MinHeight="{Binding ActualHeight, ElementName=BoardScrollViewer}"
                                              Title="进行中"
                                              Subtitle="当前正在处理"
                                              ColumnKind="{x:Static models:KanbanColumnKind.Doing}"
                                              ItemsSource="{Binding DoingTasks}"
                                              ItemTemplate="{StaticResource TaskCardTemplate}"
                                              AddCommand="{Binding CreateTaskCommand}"
                                              AddCommandParameter="{x:Static models:KanbanColumnKind.Doing}"
                                              DropCommand="{Binding MoveCardCommand}"
                                              Margin="0,0,12,0" />

                <controls:KanbanColumnControl Width="240"
                                              MinHeight="{Binding ActualHeight, ElementName=BoardScrollViewer}"
                                              Title="卡住"
                                              Subtitle="遇到阻碍或等待"
                                              ColumnKind="{x:Static models:KanbanColumnKind.Blocked}"
                                              ItemsSource="{Binding BlockedTasks}"
                                              ItemTemplate="{StaticResource TaskCardTemplate}"
                                              AddCommand="{Binding CreateTaskCommand}"
                                              AddCommandParameter="{x:Static models:KanbanColumnKind.Blocked}"
                                              DropCommand="{Binding MoveCardCommand}"
                                              Margin="0,0,12,0" />

                <controls:KanbanColumnControl Width="240"
                                              MinHeight="{Binding ActualHeight, ElementName=BoardScrollViewer}"
                                              Title="完成"
                                              Subtitle="已经处理完成"
                                              ColumnKind="{x:Static models:KanbanColumnKind.Done}"
                                              ItemsSource="{Binding DoneTasks}"
                                              ItemTemplate="{StaticResource TaskCardTemplate}"
                                              AddCommand="{Binding CreateTaskCommand}"
                                              AddCommandParameter="{x:Static models:KanbanColumnKind.Done}"
                                              DropCommand="{Binding MoveCardCommand}"
                                              Margin="0,0,12,0" />

                <controls:KanbanColumnControl Width="240"
                                              MinHeight="{Binding ActualHeight, ElementName=BoardScrollViewer}"
                                              Title="备忘录"
                                              Subtitle="灵感、备忘和随手记"
                                              ColumnKind="{x:Static models:KanbanColumnKind.Notes}"
                                              ItemsSource="{Binding Notes}"
                                              ItemTemplate="{StaticResource NoteCardTemplate}"
                                              AddCommand="{Binding CreateNoteCommand}"
                                              AddCommandParameter="{x:Static models:KanbanColumnKind.Notes}"
                                              DropCommand="{Binding MoveCardCommand}" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
