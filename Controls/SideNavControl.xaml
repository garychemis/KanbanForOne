<UserControl x:Class="KanbanForOne.Controls.SideNavControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{StaticResource SideNavBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrushSoft}"
            BorderThickness="0,0,1,0">
        <DockPanel Margin="20,24">
            <StackPanel DockPanel.Dock="Top">
                <TextBlock Text="Kanban41"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <StackPanel Margin="0,34,0,0">
                    <Button Command="{Binding ChangeFilterCommand}"
                            CommandParameter="Board"
                            Style="{StaticResource NavButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▦"
                                       Width="24"
                                       FontSize="15"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="全部任务" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ChangeFilterCommand}"
                            CommandParameter="Today"
                            Style="{StaticResource NavButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▣"
                                       Width="24"
                                       FontSize="15"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="今日任务" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ChangeFilterCommand}"
                            CommandParameter="High"
                            Style="{StaticResource NavButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="!"
                                       Width="24"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="高优先级" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>

            <StackPanel DockPanel.Dock="Bottom">
                <Button Command="{Binding ChangeFilterCommand}"
                        CommandParameter="Backup"
                        Style="{StaticResource NavButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="♧"
                                   Width="24"
                                   FontSize="15"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="数据备份" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding ChangeFilterCommand}"
                        CommandParameter="Settings"
                        Style="{StaticResource NavButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙"
                                   Width="24"
                                   FontSize="15"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="设置" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
