<UserControl x:Class="KanbanForOne.Controls.TaskCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AllowDrop="True"
             PreviewMouseLeftButtonDown="OnPreviewMouseLeftButtonDown"
             MouseMove="OnMouseMove"
             MouseLeftButtonUp="OnMouseLeftButtonUp"
             MouseEnter="OnMouseEnter"
             MouseLeave="OnMouseLeave"
             DragEnter="OnFileDragEnter"
             DragOver="OnFileDragOver"
             DragLeave="OnFileDragLeave"
             Drop="OnFileDrop">
    <Grid Margin="0,0,0,14">
        <Border x:Name="CardBorder"
                Style="{StaticResource CardBorderStyle}"
                Background="{Binding Status, Converter={StaticResource TaskStatusBackgroundConverter}}"
                BorderBrush="#EEF0F2"
                CornerRadius="8"
                MinHeight="92"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TranslateTransform x:Name="LiftTransform" />
            </Border.RenderTransform>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Background="{Binding Status, Converter={StaticResource TaskStatusBrushConverter}}"
                        CornerRadius="8,0,0,8" />

                <StackPanel Grid.Column="1"
                            Margin="18,16,18,14">
                    <TextBlock Text="{Binding Title}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{Binding Status, Converter={StaticResource DoneForegroundConverter}}"
                               TextDecorations="{Binding Status, Converter={StaticResource DoneTextDecorationConverter}}"
                               TextWrapping="Wrap" />

                    <Grid Margin="0,9,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}">
                            <Run Text="日期 " />
                            <Run Text="{Binding DateRangeDisplay, Mode=OneWay}" />
                        </TextBlock>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding Priority, Converter={StaticResource TaskPriorityNameConverter}, StringFormat=优先级 {0}}"
                                   FontSize="11"
                                   Foreground="{Binding Priority, Converter={StaticResource TaskPriorityBrushConverter}}" />
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Tags}"
                                  Margin="0,12,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="7,3"
                                        Margin="0,0,6,4"
                                        CornerRadius="8"
                                        Background="#F3F5F7">
                                    <TextBlock Text="{Binding}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="DropHint"
                Visibility="Collapsed"
                CornerRadius="8"
                Background="#CCEFF6FF"
                BorderBrush="#3B82F6"
                BorderThickness="1"
                IsHitTestVisible="False">
            <TextBlock Text="释放文件以保存为附件"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#1D4ED8" />
        </Border>
    </Grid>
</UserControl>
