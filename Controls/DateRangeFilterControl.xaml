<UserControl x:Class="KanbanForOne.Controls.DateRangeFilterControl"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="236"
             Height="38">
    <UserControl.Resources>
        <Style x:Key="TopDatePickerStyle"
               TargetType="{x:Type DatePicker}"
               BasedOn="{StaticResource DrawerDatePickerStyle}">
            <Setter Property="Width" Value="86" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>
    </UserControl.Resources>

    <Border Background="#FAFAFA"
            BorderBrush="#F1F2F4"
            BorderThickness="1"
            CornerRadius="10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="32" />
            </Grid.ColumnDefinitions>

            <DatePicker Grid.Column="1"
                        SelectedDate="{Binding StartDate, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource TopDatePickerStyle}"
                        ToolTip="&#x8D77;&#x59CB;&#x65E5;&#x671F;" />

            <TextBlock Grid.Column="2"
                       Text="&#x2014;"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />

            <DatePicker Grid.Column="4"
                        SelectedDate="{Binding EndDate, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource TopDatePickerStyle}"
                        ToolTip="&#x622A;&#x6B62;&#x65E5;&#x671F;" />

            <Button Grid.Column="6"
                    Content="&#xE711;"
                    Command="{Binding ClearCommand, ElementName=Root}"
                    FontFamily="Segoe MDL2 Assets"
                    Style="{StaticResource IconButtonStyle}"
                    Width="28"
                    Height="28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding HasFilter, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverterEx}}"
                    ToolTip="&#x6E05;&#x7A7A;&#x65F6;&#x95F4;&#x7B5B;&#x9009;" />
        </Grid>
    </Border>
</UserControl>
