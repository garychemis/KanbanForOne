<UserControl x:Class="KanbanForOne.Controls.AttachmentDropZoneControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AllowDrop="True"
             DragEnter="OnDragEnter"
             DragOver="OnDragOver"
             DragLeave="OnDragLeave"
             Drop="OnDrop">
    <Grid>
        <Border x:Name="DropBorder"
                MinHeight="92"
                Padding="18"
                CornerRadius="18"
                BorderThickness="0"
                Background="#80FFFFFF">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding TitleText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding HelperText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Margin="0,6,0,0"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border x:Name="DropHint"
                Visibility="Collapsed"
                CornerRadius="12"
                Background="#E6FFFFFF"
                BorderThickness="0"
                IsHitTestVisible="False">
            <TextBlock Text="{Binding DropHintText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="#6B5B2E" />
        </Border>
    </Grid>
</UserControl>
