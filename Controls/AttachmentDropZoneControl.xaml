<UserControl x:Class="KanbanForOne.Controls.AttachmentDropZoneControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AllowDrop="True"
             DragEnter="OnDragEnter"
             DragOver="OnDragOver"
             DragLeave="OnDragLeave"
             Drop="OnDrop">
    <Grid>
        <Border x:Name="DropBorder"
                MinHeight="64"
                Padding="14,10"
                CornerRadius="16"
                BorderThickness="0"
                Background="#99FFFFFF">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding TitleText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding HelperText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Margin="0,4,0,0"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Rectangle x:Name="DropFrame"
                   RadiusX="16"
                   RadiusY="16"
                   Stroke="#CBD5E1"
                   StrokeDashArray="5,3"
                   StrokeThickness="1"
                   IsHitTestVisible="False" />

        <Border x:Name="DropHint"
                Visibility="Collapsed"
                CornerRadius="16"
                Background="#EFF6FF"
                BorderBrush="#93C5FD"
                BorderThickness="1"
                IsHitTestVisible="False">
            <TextBlock Text="{Binding DropHintText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="#6B5B2E" />
        </Border>
    </Grid>
</UserControl>
