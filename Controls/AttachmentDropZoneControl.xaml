<UserControl x:Class="KanbanForOne.Controls.AttachmentDropZoneControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AllowDrop="True"
             DragEnter="OnDragEnter"
             DragOver="OnDragOver"
             DragLeave="OnDragLeave"
             Drop="OnDrop">
    <Grid>
        <Border x:Name="DropBorder"
                MinHeight="62"
                Padding="10"
                CornerRadius="4"
                BorderBrush="{StaticResource DrawerSoftDividerBrush}"
                BorderThickness="1"
                Background="{StaticResource DrawerSoftSurfaceBrush}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding TitleText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding HelperText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Margin="0,3,0,0"
                           FontSize="10"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border x:Name="DropHint"
                Visibility="Collapsed"
                CornerRadius="4"
                Background="#F8FAFC"
                BorderBrush="{StaticResource DrawerSoftDividerBrush}"
                BorderThickness="1"
                IsHitTestVisible="False">
            <TextBlock Text="{Binding DropHintText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="#6B5B2E" />
        </Border>
    </Grid>
</UserControl>
