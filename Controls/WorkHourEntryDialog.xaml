<Window x:Class="KanbanForOne.Controls.WorkHourEntryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="人工时详情"
        Width="520"
        Height="700"
        MinHeight="680"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        KeyDown="OnDialogKeyDown"
        Closing="OnDialogClosing">
    <Window.Resources>
        <SolidColorBrush x:Key="WorkHourDialogSurfaceBrush" Color="#F5F6F4" />
        <SolidColorBrush x:Key="WorkHourFieldBackgroundBrush" Color="#FBFCFB" />
        <SolidColorBrush x:Key="WorkHourBorderBrush" Color="#D5DBD8" />
        <SolidColorBrush x:Key="WorkHourHoverBrush" Color="#F0F3F1" />
        <SolidColorBrush x:Key="WorkHourSelectedBrush" Color="#E7ECE9" />
        <SolidColorBrush x:Key="WorkHourFocusBrush" Color="#8F9E98" />
        <SolidColorBrush x:Key="WorkHourPrimaryTextBrush" Color="#2F3A36" />
        <SolidColorBrush x:Key="WorkHourSecondaryTextBrush" Color="#68736F" />
        <Style x:Key="DialogCloseButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="Width" Value="30" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Foreground" Value="{StaticResource WorkHourSecondaryTextBrush}" />
        </Style>
        <Style x:Key="DialogGhostButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="MinWidth" Value="82" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="{StaticResource WorkHourFieldBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource WorkHourBorderBrush}" />
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource WorkHourSecondaryTextBrush}" />
        </Style>
        <Style x:Key="PreviewCardStyle" TargetType="{x:Type Border}">
            <Setter Property="Padding" Value="14,11" />
            <Setter Property="Background" Value="{StaticResource WorkHourFieldBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource WorkHourBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>
        <Style x:Key="DialogDateFieldBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="11,0,8,0" />
            <Setter Property="Background" Value="{StaticResource WorkHourFieldBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource WorkHourBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource WorkHourFocusBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DialogTextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="11,0" />
            <Setter Property="Background" Value="{StaticResource WorkHourFieldBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource WorkHourBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource WorkHourPrimaryTextBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource WorkHourPrimaryTextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="InputBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="#B9C3BF" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource WorkHourFocusBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="InputBorder" Property="Background" Value="{StaticResource WorkHourHoverBrush}" />
                                <Setter Property="Foreground" Value="#98A19D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DialogComboBoxItemStyle" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="Foreground" Value="{StaticResource WorkHourPrimaryTextBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="ItemBackground"
                                Padding="11,7"
                                CornerRadius="7"
                                Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBackground" Property="Background" Value="{StaticResource WorkHourHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBackground" Property="Background" Value="{StaticResource WorkHourSelectedBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource WorkHourPrimaryTextBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DialogComboBoxToggleStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="ToggleBackground"
                                Width="35"
                                Margin="0,1,1,1"
                                Background="Transparent"
                                CornerRadius="0,8,8,0">
                            <Grid>
                                <Border Width="1"
                                        Height="18"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource WorkHourBorderBrush}" />
                                <Path x:Name="Arrow"
                                      Width="9"
                                      Height="5"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Data="M 0 0 L 4.5 4.5 L 9 0"
                                      Stroke="{StaticResource WorkHourSecondaryTextBrush}"
                                      StrokeThickness="1.6"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBackground" Property="Background" Value="{StaticResource WorkHourHoverBrush}" />
                                <Setter TargetName="Arrow" Property="Stroke" Value="{StaticResource WorkHourPrimaryTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBackground" Property="Background" Value="{StaticResource WorkHourSelectedBrush}" />
                                <Setter TargetName="Arrow" Property="Stroke" Value="{StaticResource WorkHourPrimaryTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DialogComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Height" Value="42" />
            <Setter Property="Background" Value="{StaticResource WorkHourFieldBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource WorkHourPrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource WorkHourBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="IsTextSearchEnabled" Value="True" />
            <Setter Property="StaysOpenOnEdit" Value="True" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource DialogComboBoxItemStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="InputBackground"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="9" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="36" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter x:Name="ContentSite"
                                                  Margin="11,0,4,0"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  IsHitTestVisible="False" />
                                <TextBox x:Name="PART_EditableTextBox"
                                         Margin="11,0,4,0"
                                         Padding="0"
                                         VerticalContentAlignment="Center"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{TemplateBinding Foreground}"
                                         CaretBrush="{StaticResource WorkHourPrimaryTextBrush}"
                                         Style="{x:Null}"
                                         Visibility="Hidden" />
                                <ToggleButton Grid.Column="1"
                                              IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              Style="{StaticResource DialogComboBoxToggleStyle}" />
                            </Grid>
                            <Border x:Name="InputBorder"
                                    Background="Transparent"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="9"
                                    IsHitTestVisible="False" />
                            <Popup x:Name="PART_Popup"
                                   Margin="0,4,0,0"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="230"
                                        Padding="5"
                                        Background="{StaticResource WorkHourFieldBackgroundBrush}"
                                        BorderBrush="{StaticResource WorkHourBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="18"
                                                          ShadowDepth="6"
                                                          Direction="270"
                                                          Opacity="0.16" />
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  CanContentScroll="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden" />
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="#B9C3BF" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource WorkHourFocusBrush}" />
                                <Setter TargetName="InputBackground" Property="Background" Value="{StaticResource WorkHourFieldBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource WorkHourFocusBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="InputBackground" Property="Background" Value="{StaticResource WorkHourHoverBrush}" />
                                <Setter Property="Foreground" Value="#9AA4A0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="DialogChrome"
          Margin="18"
          Opacity="0"
          RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <ScaleTransform ScaleX="0.96" ScaleY="0.96" />
        </Grid.RenderTransform>
        <Border Background="{StaticResource WorkHourDialogSurfaceBrush}"
                BorderBrush="{StaticResource WorkHourBorderBrush}"
                BorderThickness="1"
                TextElement.Foreground="{StaticResource WorkHourPrimaryTextBrush}"
                CornerRadius="18">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="10" Direction="270" Opacity="0.18" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="20,14,16,14"
                        Background="{StaticResource WorkHourDialogSurfaceBrush}"
                        BorderThickness="0"
                        CornerRadius="18,18,0,0"
                        MouseLeftButtonDown="OnHeaderMouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                             <TextBlock x:Name="DialogTitleText"
                                        Text="人工时详情"
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource WorkHourPrimaryTextBrush}" />
                            <TextBlock x:Name="DialogSubtitleText"
                                       Margin="0,3,0,0"
                                       FontSize="11"
                                        Foreground="{StaticResource WorkHourSecondaryTextBrush}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="&#x00D7;"
                                Click="OnCloseClick"
                                Style="{StaticResource DialogCloseButtonStyle}" />
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <ScrollViewer x:Name="PreviewPanel"
                                  Padding="22,20"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource PreviewCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="日期" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock x:Name="PreviewDateText" FontSize="14" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource PreviewCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="工时" Style="{StaticResource FieldLabelStyle}" />
                                         <TextBlock x:Name="PreviewHoursText"
                                                    FontSize="18"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource WorkHourPrimaryTextBrush}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <Border Margin="0,12,0,0" Style="{StaticResource PreviewCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="项目号" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock x:Name="PreviewProjectNumberText" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource PreviewCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="专业" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock x:Name="PreviewDisciplineText" FontSize="14" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource PreviewCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="工作内容" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock x:Name="PreviewActivityText" FontSize="14" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <Border Margin="0,12,0,0" Style="{StaticResource PreviewCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="备注" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock x:Name="PreviewRemarkText" FontSize="13" LineHeight="20" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer x:Name="EditPanel"
                                  Padding="22,18"
                                  VerticalContentAlignment="Stretch"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="日期" Style="{StaticResource FieldLabelStyle}" />
                            <Border Grid.Row="1" Style="{StaticResource DialogDateFieldBorderStyle}">
                                <DatePicker x:Name="WorkDatePicker"
                                            Style="{StaticResource DrawerDatePickerStyle}"
                                            Foreground="{StaticResource WorkHourPrimaryTextBrush}" />
                            </Border>

                            <TextBlock Grid.Row="2"
                                       Text="项目号"
                                       Margin="0,14,0,6"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Row="3"
                                     x:Name="ProjectNumberTextBox"
                                     Style="{StaticResource DialogTextBoxStyle}"
                                     LostKeyboardFocus="OnProjectNumberLostKeyboardFocus" />

                            <Grid Grid.Row="4" Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="专业" Style="{StaticResource FieldLabelStyle}" />
                                    <ComboBox x:Name="DisciplineComboBox"
                                              IsEditable="True"
                                              Style="{StaticResource DialogComboBoxStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="工作内容" Style="{StaticResource FieldLabelStyle}" />
                                    <ComboBox x:Name="ActivityComboBox"
                                              IsEditable="True"
                                              Style="{StaticResource DialogComboBoxStyle}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Grid.Row="5"
                                       Text="工时（小时）"
                                       Margin="0,14,0,6"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Row="6"
                                     x:Name="HoursTextBox"
                                     Style="{StaticResource DialogTextBoxStyle}" />

                            <TextBlock Grid.Row="7"
                                       Text="备注（选填）"
                                       Margin="0,14,0,6"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Row="8"
                                     x:Name="RemarkTextBox"
                                     Height="Auto"
                                     MinHeight="82"
                                     Padding="11,9"
                                     Style="{StaticResource DialogTextBoxStyle}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalAlignment="Stretch"
                                     VerticalContentAlignment="Top" />

                            <TextBlock Grid.Row="9"
                                       x:Name="ValidationText"
                                       Margin="0,10,0,0"
                                       FontSize="12"
                                       Foreground="#BE123C"
                                       TextWrapping="Wrap"
                                       Visibility="Collapsed" />
                        </Grid>
                    </ScrollViewer>
                </Grid>

                <Border Grid.Row="2"
                        Padding="18,14"
                        Background="{StaticResource WorkHourDialogSurfaceBrush}"
                        BorderThickness="0"
                        CornerRadius="0,0,18,18">
                    <Grid>
                        <StackPanel x:Name="PreviewActions" Orientation="Horizontal">
                            <Button Content="删除"
                                    Click="OnDeleteClick"
                                    Style="{StaticResource DialogGhostButtonStyle}"
                                    Foreground="#BE123C" />
                            <Button Content="编辑"
                                    Click="OnEditClick"
                                    Margin="10,0,0,0"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                        </StackPanel>
                        <StackPanel x:Name="EditActions"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Visibility="Collapsed">
                            <Button Content="取消"
                                    Click="OnCancelEditClick"
                                    Style="{StaticResource DialogGhostButtonStyle}" />
                            <Button Content="保存"
                                    Click="OnSaveClick"
                                    Margin="10,0,0,0"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
