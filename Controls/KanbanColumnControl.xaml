<UserControl x:Class="KanbanForOne.Controls.KanbanColumnControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:KanbanForOne.Controls"
             xmlns:models="clr-namespace:KanbanForOne.Models"
             MinWidth="280"
             MaxWidth="360">
    <Border x:Name="ColumnBorder"
            AllowDrop="True"
            DragEnter="OnDragEnter"
            DragOver="OnDragOver"
            DragLeave="OnDragLeave"
            Drop="OnDrop"
            Background="Transparent"
            BorderThickness="0"
            Padding="0">
        <DockPanel>
            <Grid DockPanel.Dock="Top"
                  Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="7" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               FontSize="21"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding Subtitle, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Margin="0,3,0,0"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Visibility="Collapsed" />
                </StackPanel>

                <Border Grid.Column="1"
                        Width="20"
                        Height="20"
                        CornerRadius="10"
                        Background="#F0F1F3"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding ElementName=CardItems, Path=Items.Count, Mode=OneWay}"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <Button Grid.Column="3"
                        Content="+"
                        Command="{Binding AddCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding AddCommandParameter, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Style="{StaticResource IconButtonStyle}"
                        Width="22"
                        Height="22"
                        Opacity="0.55"
                        ToolTip="添加卡片" />
            </Grid>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <ItemsControl x:Name="CardItems"
                                  ItemsSource="{Binding ItemsSource, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  ItemTemplate="{Binding ItemTemplate, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <local:EmptyStateControl x:Name="ColumnEmptyState"
                                             Title="暂无卡片"
                                             Message="点击右上角 + 添加一张卡片。"
                                             Visibility="Collapsed"
                                             Margin="0,4,0,0" />
                </Grid>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
