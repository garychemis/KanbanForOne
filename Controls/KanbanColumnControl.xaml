<UserControl x:Class="KanbanForOne.Controls.KanbanColumnControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:KanbanForOne.Controls"
             xmlns:models="clr-namespace:KanbanForOne.Models"
             MinWidth="232"
             MaxWidth="360">
    <Border x:Name="ColumnBorder"
            AllowDrop="True"
            DragEnter="OnDragEnter"
            DragOver="OnDragOver"
            DragLeave="OnDragLeave"
            PreviewDrop="OnPreviewDrop"
            Drop="OnDrop"
            MouseEnter="OnColumnMouseEnter"
            MouseLeave="OnColumnMouseLeave"
            Background="{StaticResource ColumnBackgroundBrush}"
            BorderBrush="#55FFFFFF"
            BorderThickness="1"
            CornerRadius="18"
            Padding="10,10,10,12">
        <DockPanel>
            <Grid DockPanel.Dock="Top"
                  Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="7" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               FontSize="21"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding Subtitle, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Margin="0,3,0,0"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Visibility="Collapsed" />
                </StackPanel>

                <Border Grid.Column="1"
                        Width="20"
                        Height="20"
                        CornerRadius="10"
                        Background="#F0F1F3"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding ElementName=CardItems, Path=Items.Count, Mode=OneWay}"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <Button Grid.Column="3"
                        x:Name="AddButton"
                        Content="+"
                        Click="OnAddButtonClick"
                        Style="{StaticResource IconButtonStyle}"
                        Width="24"
                        MinWidth="24"
                        Height="24"
                        Padding="0"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Opacity="0.78"
                        Visibility="{Binding IsArchiveFilter, Converter={StaticResource BooleanToVisibilityConverterEx}, ConverterParameter=Invert}"
                        ToolTip="添加卡片" />
            </Grid>

            <ScrollViewer x:Name="CardsScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid MinHeight="{Binding ActualHeight, ElementName=CardsScrollViewer}">
                    <ItemsControl x:Name="CardItems"
                                  ItemsSource="{Binding ItemsSource, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  ItemTemplate="{Binding ItemTemplate, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <local:EmptyStateControl x:Name="ColumnEmptyState"
                                             Title="暂无卡片"
                                             Message="点击右上角 + 添加一张卡片。"
                                             Visibility="Collapsed"
                                             Margin="0,4,0,0" />

                    <Border x:Name="DropIndicator"
                            Visibility="Collapsed"
                            Height="4"
                            Margin="6,2,6,0"
                            CornerRadius="2"
                            Background="#3B82F6"
                            BorderBrush="#3B82F6"
                            BorderThickness="0"
                            IsHitTestVisible="False"
                            Opacity="0.9"
                            VerticalAlignment="Top">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8"
                                              ShadowDepth="1"
                                              Direction="270"
                                              Opacity="0.16" />
                        </Border.Effect>
                    </Border>

                    <Border x:Name="ColumnDropZone"
                            Height="42"
                            Margin="2,12,2,0"
                            CornerRadius="14"
                            Background="#00FFFFFF"
                            BorderBrush="#66CBD5E1"
                            BorderThickness="1"
                            VerticalAlignment="Bottom"
                            Opacity="0.18"
                            IsHitTestVisible="False">
                        <TextBlock Text="拖拽任务到这里"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </Border>
                </Grid>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
