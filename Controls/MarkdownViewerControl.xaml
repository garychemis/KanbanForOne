<UserControl x:Class="KanbanForOne.Controls.MarkdownViewerControl"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="92">
    <Border Padding="14"
            CornerRadius="11"
            Background="{Binding ViewerBackground, ElementName=Root}"
            BorderBrush="{Binding ViewerBorderBrush, ElementName=Root}"
            BorderThickness="1">
        <FlowDocumentScrollViewer x:Name="Viewer"
                                  IsToolBarVisible="False"
                                  VerticalScrollBarVisibility="Auto" />
    </Border>
</UserControl>
