<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:KanbanForOne.Converters">
    <converters:TaskStatusBrushConverter x:Key="TaskStatusBrushConverter" />
    <converters:TaskStatusBackgroundConverter x:Key="TaskStatusBackgroundConverter" />
    <converters:TaskStatusDrawerBackgroundConverter x:Key="TaskStatusDrawerBackgroundConverter" />
    <converters:TaskStatusNameConverter x:Key="TaskStatusNameConverter" />
    <converters:TaskPriorityBrushConverter x:Key="TaskPriorityBrushConverter" />
    <converters:TaskPriorityNameConverter x:Key="TaskPriorityNameConverter" />
    <converters:EnumEqualsConverter x:Key="EnumEqualsConverter" />
    <converters:DoneTextDecorationConverter x:Key="DoneTextDecorationConverter" />
    <converters:DoneForegroundConverter x:Key="DoneForegroundConverter" />
    <converters:DateDisplayConverter x:Key="DateDisplayConverter" />
    <converters:AttachmentSizeConverter x:Key="AttachmentSizeConverter" />
    <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    <converters:BooleanToVisibilityConverterEx x:Key="BooleanToVisibilityConverterEx" />
    <converters:FilterSelectedBackgroundConverter x:Key="FilterSelectedBackgroundConverter" />
    <converters:CollectionEmptyToVisibilityConverter x:Key="CollectionEmptyToVisibilityConverter" />
    <converters:TagDisplayConverter x:Key="TagDisplayConverter" />
    <converters:TagListDisplayConverter x:Key="TagListDisplayConverter" />

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#ECEEEF" />
    <SolidColorBrush x:Key="MainContentBackgroundBrush" Color="#ECEEEF" />
    <SolidColorBrush x:Key="SideNavBackgroundBrush" Color="#FAF7EF" />
    <SolidColorBrush x:Key="TopNavBackgroundBrush" Color="#F4F5F3" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#111827" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6B7280" />
    <SolidColorBrush x:Key="BorderBrushSoft" Color="#D8DADF" />
    <SolidColorBrush x:Key="SelectedBackgroundBrush" Color="#E7E1D6" />
    <SolidColorBrush x:Key="ColumnBackgroundBrush" Color="#00FFFFFF" />
    <SolidColorBrush x:Key="NoteCardBackgroundBrush" Color="#FFF8B7" />
    <SolidColorBrush x:Key="NoteCardBorderBrush" Color="#F7E98A" />

    <FontFamily x:Key="AppFontFamily">Segoe UI Variable, Segoe UI, Microsoft YaHei UI, Microsoft YaHei</FontFamily>

    <Style TargetType="{x:Type Window}">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="IconButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F1F3F5" />
                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{StaticResource SelectedBackgroundBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource IconButtonStyle}">
        <Setter Property="MinWidth" Value="96" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Background" Value="#212529" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="BorderBrush" Value="#212529" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#343A40" />
                            <Setter Property="BorderBrush" Value="#343A40" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#111315" />
                            <Setter Property="BorderBrush" Value="#111315" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="#ADB5BD" />
                            <Setter Property="BorderBrush" Value="#ADB5BD" />
                            <Setter Property="Opacity" Value="0.72" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NavButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Height" Value="40" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="Margin" Value="0,4" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Chrome"
                            CornerRadius="7">
                        <Border.Background>
                            <MultiBinding Converter="{StaticResource FilterSelectedBackgroundConverter}">
                                <Binding Path="DataContext.CurrentFilter"
                                         RelativeSource="{RelativeSource TemplatedParent}" />
                                <Binding Path="CommandParameter"
                                         RelativeSource="{RelativeSource TemplatedParent}" />
                            </MultiBinding>
                        </Border.Background>
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#EEF1F4" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SelectedBackgroundBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TextInputStyle" TargetType="{x:Type TextBox}">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter Property="BorderBrush" Value="#AEB6C0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CardBorderStyle" TargetType="{x:Type Border}">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="#E6E8EB" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="16"
                                  ShadowDepth="5"
                                  Direction="270"
                                  Opacity="0.07" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ListCardButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.94" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Opacity" Value="0.82" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
