<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:KanbanForOne.Controls"
                    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
    <SolidColorBrush x:Key="DrawerPanelBackgroundBrush" Color="#F7F8FA" />
    <SolidColorBrush x:Key="DrawerNoteBackgroundBrush" Color="#FFF9E8" />
    <SolidColorBrush x:Key="DrawerTextPrimaryBrush" Color="#1F2937" />
    <SolidColorBrush x:Key="DrawerTextSecondaryBrush" Color="#334155" />
    <SolidColorBrush x:Key="DrawerMutedBrush" Color="#64748B" />
    <SolidColorBrush x:Key="DrawerSoftDividerBrush" Color="#D6DEE8" />
    <SolidColorBrush x:Key="DrawerSoftSurfaceBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="DrawerStrongSurfaceBrush" Color="#E9EEF5" />

    <Style x:Key="DrawerPanelStyle" TargetType="{x:Type Border}">
        <Setter Property="CornerRadius" Value="10,0,0,10" />
        <Setter Property="Background" Value="{StaticResource DrawerPanelBackgroundBrush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    </Style>

    <Style x:Key="DrawerRootStyle" TargetType="{x:Type Grid}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="KeyboardNavigation.TabNavigation" Value="Cycle" />
    </Style>

    <Style x:Key="DrawerHeaderStyle" TargetType="{x:Type Border}">
        <Setter Property="Padding" Value="24,20,24,12" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    </Style>

    <Style x:Key="DrawerFooterStyle" TargetType="{x:Type Border}">
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="MinHeight" Value="54" />
        <Setter Property="Background" Value="#EEF2F7" />
        <Setter Property="BorderBrush" Value="{StaticResource DrawerSoftDividerBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    </Style>

    <Style x:Key="DrawerTitleTextBoxStyle" TargetType="{x:Type TextBox}">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource DrawerTextPrimaryBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource DrawerTextPrimaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <ScrollViewer x:Name="PART_ContentHost"
                                  Margin="{TemplateBinding Padding}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="BorderlessDrawerSectionStyle" TargetType="{x:Type StackPanel}">
        <Setter Property="Margin" Value="0,0,0,14" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    </Style>

    <Style x:Key="BorderlessDrawerSectionTitleStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource DrawerMutedBrush}" />
        <Setter Property="Margin" Value="0,0,0,7" />
    </Style>

    <Style x:Key="DrawerSectionTitleStyle"
           TargetType="{x:Type TextBlock}"
           BasedOn="{StaticResource BorderlessDrawerSectionTitleStyle}" />

    <Style x:Key="DrawerSegmentToggleStyle" TargetType="{x:Type RadioButton}">
        <Setter Property="Height" Value="30" />
        <Setter Property="MinWidth" Value="68" />
        <Setter Property="Margin" Value="0,0,6,6" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource DrawerTextSecondaryBrush}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RadioButton}">
                    <Border x:Name="Chrome"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="4"
                            Background="{StaticResource DrawerSoftSurfaceBrush}"
                            BorderBrush="{StaticResource DrawerSoftDividerBrush}"
                            BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource DrawerStrongSurfaceBrush}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Foreground" Value="{StaticResource DrawerTextPrimaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#F3F6FA" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DrawerChipButtonStyle"
           TargetType="{x:Type RadioButton}"
           BasedOn="{StaticResource DrawerSegmentToggleStyle}" />

    <Style x:Key="BorderlessChipButtonStyle"
           TargetType="{x:Type RadioButton}"
           BasedOn="{StaticResource DrawerSegmentToggleStyle}" />

    <Style x:Key="BorderlessChipButtonSelectedStyle"
           TargetType="{x:Type RadioButton}"
           BasedOn="{StaticResource DrawerSegmentToggleStyle}" />

    <Style x:Key="DrawerStatusChipButtonStyle" TargetType="{x:Type RadioButton}">
        <Setter Property="Height" Value="30" />
        <Setter Property="MinWidth" Value="68" />
        <Setter Property="Margin" Value="0,0,6,6" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground">
            <Setter.Value>
                <Binding Path="Tag"
                         RelativeSource="{RelativeSource Self}"
                         Converter="{StaticResource TaskStatusBrushConverter}" />
            </Setter.Value>
        </Setter>
        <Setter Property="Background">
            <Setter.Value>
                <Binding Path="Tag"
                         RelativeSource="{RelativeSource Self}"
                         Converter="{StaticResource TaskStatusBackgroundConverter}" />
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <Binding Path="Tag"
                         RelativeSource="{RelativeSource Self}"
                         Converter="{StaticResource TaskStatusBrushConverter}" />
            </Setter.Value>
        </Setter>
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RadioButton}">
                    <Border x:Name="Chrome"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="4"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            Opacity="0.78">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Opacity" Value="0.92" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Chrome" Property="Opacity" Value="1" />
                            <Setter TargetName="Chrome" Property="BorderThickness" Value="2" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DrawerScrollBarRepeatButtonStyle" TargetType="{x:Type primitives:RepeatButton}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type primitives:RepeatButton}">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DrawerScrollBarThumbStyle" TargetType="{x:Type primitives:Thumb}">
        <Setter Property="Background" Value="#CBD5E1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                    <Border x:Name="ThumbChrome"
                            Margin="2,0"
                            CornerRadius="4"
                            Background="{TemplateBinding Background}" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbChrome" Property="Background" Value="#94A3B8" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbChrome" Property="Background" Value="#64748B" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DrawerScrollBarStyle" TargetType="{x:Type ScrollBar}">
        <Setter Property="Width" Value="8" />
        <Setter Property="MinWidth" Value="8" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <Grid Width="{TemplateBinding Width}"
                          Background="{TemplateBinding Background}">
                        <primitives:Track x:Name="PART_Track"
                                          IsDirectionReversed="True">
                            <primitives:Track.DecreaseRepeatButton>
                                <primitives:RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                          Style="{StaticResource DrawerScrollBarRepeatButtonStyle}" />
                            </primitives:Track.DecreaseRepeatButton>
                            <primitives:Track.Thumb>
                                <primitives:Thumb Style="{StaticResource DrawerScrollBarThumbStyle}" />
                            </primitives:Track.Thumb>
                            <primitives:Track.IncreaseRepeatButton>
                                <primitives:RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                          Style="{StaticResource DrawerScrollBarRepeatButtonStyle}" />
                            </primitives:Track.IncreaseRepeatButton>
                        </primitives:Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="BorderlessDateCardStyle" TargetType="{x:Type Border}">
        <Setter Property="Height" Value="58" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Background" Value="{StaticResource DrawerSoftSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DrawerSoftDividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    </Style>

    <Style x:Key="DrawerDateCardStyle"
           TargetType="{x:Type Border}"
           BasedOn="{StaticResource BorderlessDateCardStyle}" />

    <Style x:Key="DrawerDatePickerStyle" TargetType="{x:Type DatePicker}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource DrawerTextPrimaryBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DatePicker}">
                    <Grid x:Name="PART_Root">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <primitives:DatePickerTextBox x:Name="PART_TextBox"
                                                       Background="Transparent"
                                                       BorderThickness="0"
                                                       FocusVisualStyle="{x:Null}"
                                                       Foreground="{TemplateBinding Foreground}"
                                                       FontSize="{TemplateBinding FontSize}"
                                                       Padding="0"
                                                       VerticalContentAlignment="Center" />
                        <Button x:Name="PART_Button"
                                Grid.Column="1"
                                Width="24"
                                Height="24"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                FocusVisualStyle="{x:Null}">
                            <TextBlock Text="&#xE787;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="13"
                                       Foreground="{StaticResource DrawerMutedBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Placement="Bottom"
                               PlacementTarget="{Binding ElementName=PART_TextBox}"
                               StaysOpen="False">
                            <Border Padding="8"
                                    CornerRadius="16"
                                    Background="#FFFFFF">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="22"
                                                      ShadowDepth="8"
                                                      Opacity="0.16" />
                                </Border.Effect>
                                <Calendar x:Name="PART_Calendar"
                                          BorderThickness="0" />
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DrawerDescriptionTextBoxStyle" TargetType="{x:Type TextBox}">
        <Setter Property="MinHeight" Value="260" />
        <Setter Property="Padding" Value="14" />
        <Setter Property="Background" Value="{StaticResource DrawerSoftSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DrawerSoftDividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource DrawerTextPrimaryBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource DrawerTextPrimaryBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="VerticalContentAlignment" Value="Top" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="0">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DrawerTextBoxStyle"
           TargetType="{x:Type TextBox}"
           BasedOn="{StaticResource DrawerDescriptionTextBoxStyle}" />

    <Style x:Key="DrawerDescriptionEditorStyle" TargetType="{x:Type controls:MarkdownEditorControl}">
        <Setter Property="EditorBackground" Value="{StaticResource DrawerSoftSurfaceBrush}" />
        <Setter Property="EditorForeground" Value="{StaticResource DrawerTextPrimaryBrush}" />
        <Setter Property="EditorBorderBrush" Value="{StaticResource DrawerSoftDividerBrush}" />
        <Setter Property="EditorBorderThickness" Value="1" />
        <Setter Property="EditorCornerRadius" Value="0" />
        <Setter Property="EditorPadding" Value="14" />
        <Setter Property="EditorMinHeight" Value="300" />
    </Style>

    <Style x:Key="BorderlessAttachmentDropZoneStyle" TargetType="{x:Type controls:AttachmentDropZoneControl}">
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="MinHeight" Value="64" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    </Style>

    <Style x:Key="DrawerAttachmentDropZoneStyle"
           TargetType="{x:Type controls:AttachmentDropZoneControl}"
           BasedOn="{StaticResource BorderlessAttachmentDropZoneStyle}" />

    <Style x:Key="DrawerGhostButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Height" Value="32" />
        <Setter Property="MinWidth" Value="72" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Background" Value="{StaticResource DrawerSoftSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DrawerSoftDividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource DrawerTextSecondaryBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#F3F6FA" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource DrawerStrongSurfaceBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DrawerSecondaryButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource DrawerGhostButtonStyle}" />

    <Style x:Key="BorderlessFooterButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource DrawerGhostButtonStyle}" />

    <Style x:Key="DrawerDangerButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource DrawerGhostButtonStyle}">
        <Setter Property="Background" Value="#FFF1F2" />
        <Setter Property="BorderBrush" Value="#FECDD3" />
        <Setter Property="Foreground" Value="#BE123C" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#FFE4E6" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#FECDD3" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="BorderlessDangerButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource DrawerDangerButtonStyle}" />

    <Style x:Key="DrawerPrimaryButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource DrawerGhostButtonStyle}">
        <Setter Property="Background" Value="#1F2937" />
        <Setter Property="BorderBrush" Value="#1F2937" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="MinWidth" Value="86" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#334155" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="#334155" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#111827" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="#111827" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Chrome" Property="Background" Value="#94A3B8" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="#94A3B8" />
                            <Setter Property="Opacity" Value="0.44" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="BorderlessPrimaryButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource DrawerPrimaryButtonStyle}" />

    <Style x:Key="DrawerCloseButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource IconButtonStyle}">
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="30" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Foreground" Value="{StaticResource DrawerTextSecondaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource DrawerSoftSurfaceBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource DrawerStrongSurfaceBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
