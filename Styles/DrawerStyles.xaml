<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:KanbanForOne.Controls"
                    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
    <SolidColorBrush x:Key="DrawerPanelBackgroundBrush" Color="#FFFDF6" />
    <SolidColorBrush x:Key="DrawerNoteBackgroundBrush" Color="#FFF9DB" />
    <SolidColorBrush x:Key="DrawerMutedBrush" Color="#6E655B" />
    <SolidColorBrush x:Key="DrawerSoftDividerBrush" Color="#14000000" />
    <SolidColorBrush x:Key="DrawerSoftSurfaceBrush" Color="#B3FFFFFF" />
    <SolidColorBrush x:Key="DrawerStrongSurfaceBrush" Color="#F2FFFFFF" />

    <Style x:Key="DrawerPanelStyle" TargetType="{x:Type Border}">
        <Setter Property="CornerRadius" Value="28,0,0,28" />
        <Setter Property="Background" Value="{StaticResource DrawerPanelBackgroundBrush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    </Style>

    <Style x:Key="DrawerRootStyle" TargetType="{x:Type Grid}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="KeyboardNavigation.TabNavigation" Value="Cycle" />
    </Style>

    <Style x:Key="DrawerHeaderStyle" TargetType="{x:Type Border}">
        <Setter Property="Padding" Value="34,32,34,22" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    </Style>

    <Style x:Key="DrawerFooterStyle" TargetType="{x:Type Border}">
        <Setter Property="Padding" Value="26,17" />
        <Setter Property="MinHeight" Value="86" />
        <Setter Property="Background" Value="#33FFFFFF" />
        <Setter Property="BorderBrush" Value="{StaticResource DrawerSoftDividerBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    </Style>

    <Style x:Key="DrawerTitleTextBoxStyle" TargetType="{x:Type TextBox}">
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <ScrollViewer x:Name="PART_ContentHost"
                                  Margin="{TemplateBinding Padding}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="BorderlessDrawerSectionStyle" TargetType="{x:Type StackPanel}">
        <Setter Property="Margin" Value="0,0,0,28" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    </Style>

    <Style x:Key="BorderlessDrawerSectionTitleStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource DrawerMutedBrush}" />
        <Setter Property="Margin" Value="0,0,0,11" />
    </Style>

    <Style x:Key="DrawerSectionTitleStyle"
           TargetType="{x:Type TextBlock}"
           BasedOn="{StaticResource BorderlessDrawerSectionTitleStyle}" />

    <Style x:Key="DrawerSegmentToggleStyle" TargetType="{x:Type RadioButton}">
        <Setter Property="Height" Value="40" />
        <Setter Property="MinWidth" Value="86" />
        <Setter Property="Margin" Value="0,0,8,8" />
        <Setter Property="Padding" Value="15,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="#3F4852" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RadioButton}">
                    <Border x:Name="Chrome"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="14"
                            Background="#80FFFFFF"
                            BorderThickness="0">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#F2FFFFFF" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Foreground" Value="#1F2937" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#D9FFFFFF" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DrawerChipButtonStyle"
           TargetType="{x:Type RadioButton}"
           BasedOn="{StaticResource DrawerSegmentToggleStyle}" />

    <Style x:Key="BorderlessChipButtonStyle"
           TargetType="{x:Type RadioButton}"
           BasedOn="{StaticResource DrawerSegmentToggleStyle}" />

    <Style x:Key="BorderlessChipButtonSelectedStyle"
           TargetType="{x:Type RadioButton}"
           BasedOn="{StaticResource DrawerSegmentToggleStyle}" />

    <Style x:Key="BorderlessDateCardStyle" TargetType="{x:Type Border}">
        <Setter Property="Height" Value="76" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Background" Value="{StaticResource DrawerSoftSurfaceBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    </Style>

    <Style x:Key="DrawerDateCardStyle"
           TargetType="{x:Type Border}"
           BasedOn="{StaticResource BorderlessDateCardStyle}" />

    <Style x:Key="DrawerDatePickerStyle" TargetType="{x:Type DatePicker}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="#1F2937" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DatePicker}">
                    <Grid x:Name="PART_Root">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <primitives:DatePickerTextBox x:Name="PART_TextBox"
                                                       Background="Transparent"
                                                       BorderThickness="0"
                                                       FocusVisualStyle="{x:Null}"
                                                       Foreground="{TemplateBinding Foreground}"
                                                       FontSize="{TemplateBinding FontSize}"
                                                       Padding="0"
                                                       VerticalContentAlignment="Center" />
                        <Button x:Name="PART_Button"
                                Grid.Column="1"
                                Width="24"
                                Height="24"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                FocusVisualStyle="{x:Null}">
                            <TextBlock Text="&#xE787;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="13"
                                       Foreground="{StaticResource DrawerMutedBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Placement="Bottom"
                               PlacementTarget="{Binding ElementName=PART_TextBox}"
                               StaysOpen="False">
                            <Border Padding="8"
                                    CornerRadius="16"
                                    Background="#FFFFFF">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="22"
                                                      ShadowDepth="8"
                                                      Opacity="0.16" />
                                </Border.Effect>
                                <Calendar x:Name="PART_Calendar"
                                          BorderThickness="0" />
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DrawerDescriptionTextBoxStyle" TargetType="{x:Type TextBox}">
        <Setter Property="MinHeight" Value="200" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="Background" Value="#F2FFFFFF" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="#24313D" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="VerticalContentAlignment" Value="Top" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="20">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DrawerTextBoxStyle"
           TargetType="{x:Type TextBox}"
           BasedOn="{StaticResource DrawerDescriptionTextBoxStyle}" />

    <Style x:Key="DrawerDescriptionEditorStyle" TargetType="{x:Type controls:MarkdownEditorControl}">
        <Setter Property="EditorBackground" Value="#F2FFFFFF" />
        <Setter Property="EditorBorderBrush" Value="Transparent" />
        <Setter Property="EditorBorderThickness" Value="0" />
        <Setter Property="EditorCornerRadius" Value="20" />
        <Setter Property="EditorPadding" Value="20" />
        <Setter Property="EditorMinHeight" Value="220" />
    </Style>

    <Style x:Key="BorderlessAttachmentDropZoneStyle" TargetType="{x:Type controls:AttachmentDropZoneControl}">
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="MinHeight" Value="92" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    </Style>

    <Style x:Key="DrawerAttachmentDropZoneStyle"
           TargetType="{x:Type controls:AttachmentDropZoneControl}"
           BasedOn="{StaticResource BorderlessAttachmentDropZoneStyle}" />

    <Style x:Key="DrawerGhostButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Height" Value="46" />
        <Setter Property="MinWidth" Value="92" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="Background" Value="#80FFFFFF" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="#344054" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            CornerRadius="16">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#D9FFFFFF" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#F2FFFFFF" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DrawerSecondaryButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource DrawerGhostButtonStyle}" />

    <Style x:Key="BorderlessFooterButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource DrawerGhostButtonStyle}" />

    <Style x:Key="DrawerDangerButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource DrawerGhostButtonStyle}">
        <Setter Property="Background" Value="#FFF1F2" />
        <Setter Property="Foreground" Value="#B4232C" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            CornerRadius="16">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#FFE4E6" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#FECDD3" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="BorderlessDangerButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource DrawerDangerButtonStyle}" />

    <Style x:Key="DrawerPrimaryButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource DrawerGhostButtonStyle}">
        <Setter Property="Background" Value="#1E293B" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="MinWidth" Value="122" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            CornerRadius="16">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#334155" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#0F172A" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Chrome" Property="Background" Value="#1E293B" />
                            <Setter Property="Opacity" Value="0.44" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="BorderlessPrimaryButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource DrawerPrimaryButtonStyle}" />

    <Style x:Key="DrawerCloseButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource IconButtonStyle}">
        <Setter Property="Width" Value="38" />
        <Setter Property="Height" Value="38" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="Foreground" Value="#475569" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    </Style>
</ResourceDictionary>
